{% extends 'admin/layout.html.twig' %}

{% block title %}Reservation Details{% endblock %}

{% block body %}

<div class="container py-4">

    {# PAGE HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">
                Reservation #{{ reservation.id }}
            </h1>

            <p class="text-muted mb-0">
                Reservation details and verification
            </p>

        </div>

        <a href="{{ path('app_reservation_index') }}"
           class="btn btn-outline-secondary">

            ← Back

        </a>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body p-4">

            <div class="row g-4">

                {# LEFT SIDE #}
                <div class="col-lg-6">

                    <table class="table table-bordered align-middle">

                        <tbody>

                            <tr>
                                <th width="35%">Customer</th>
                                <td>{{ reservation.fullName }}</td>
                            </tr>

                            <tr>
                                <th>Phone</th>
                                <td>{{ reservation.phoneNumber }}</td>
                            </tr>

                            <tr>
                                <th>User Email</th>
                                <td>{{ reservation.user.email }}</td>
                            </tr>

                            <tr>
                                <th>Car</th>

                                <td>
                                    {{ reservation.car.brand }}
                                    {{ reservation.car.model }}
                                </td>

                            </tr>

                            <tr>
                                <th>Start Date</th>

                                <td>
                                    {{ reservation.startDate|date('d M Y') }}
                                </td>

                            </tr>

                            <tr>
                                <th>End Date</th>

                                <td>
                                    {{ reservation.endDate|date('d M Y') }}
                                </td>

                            </tr>

                            <tr>
                                <th>Total Price</th>

                                <td class="fw-bold text-success">
                                    {{ reservation.totalPrice }} €
                                </td>

                            </tr>

                            {# PAYMENT STATUS #}
                            <tr>
                                <th>Payment</th>

                                <td>

                                    {% if reservation.paymentStatus == 'paid' %}

                                        <span class="badge bg-success">
                                            Paid
                                        </span>

                                    {% else %}

                                        <span class="badge bg-warning text-dark">
                                            Unpaid
                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                            <tr>
                                <th>License Check</th>

                                <td>

                                    {% if reservation.licenseIssueDate %}

                                        {% set difference = date().diff(reservation.licenseIssueDate) %}

                                        {% if difference.y >= 2 %}

                                            <span class="badge bg-success">
                                                ✅ OK
                                            </span>

                                        {% else %}

                                            <span class="badge bg-danger">
                                                ❌ Not OK
                                            </span>

                                        {% endif %}

                                    {% else %}

                                        <span class="badge bg-secondary">
                                            N/A
                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                            <tr>
                                <th>Status</th>

                                <td>

                                    {% if reservation.status == 'pending' %}

                                        <span class="badge bg-warning text-dark">
                                            Pending
                                        </span>

                                    {% elseif reservation.status == 'approved' %}

                                        <span class="badge bg-success">
                                            Approved
                                        </span>

                                    {% elseif reservation.status == 'rejected' %}

                                        <span class="badge bg-danger">
                                            Rejected
                                        </span>

                                    {% elseif reservation.status == 'completed' %}

                                        <span class="badge bg-primary">
                                            Completed
                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                        </tbody>

                    </table>

                    {# ACTION BUTTONS #}
                    <div class="d-flex gap-3 mt-4 flex-wrap">

                        {# PENDING #}
                        {% if reservation.status == 'pending' %}

                            <form method="post"
                                  action="{{ path('app_reservation_approve', {'id': reservation.id}) }}">

                                <button class="btn btn-success">
                                    ✅ Approve Reservation
                                </button>

                            </form>

                            <form method="post"
                                  action="{{ path('app_reservation_reject', {'id': reservation.id}) }}">

                                <button class="btn btn-danger">
                                    ❌ Reject
                                </button>

                            </form>

                        {% endif %}

                        {# APPROVED + UNPAID #}
                        {% if reservation.status == 'approved'
                            and reservation.paymentStatus == 'unpaid' %}

                            <form method="post"
                                  action="{{ path('app_reservation_confirm_payment', {'id': reservation.id}) }}">

                                <button class="btn btn-warning text-dark">
                                    💵 Confirm Payment
                                </button>

                            </form>

                        {% endif %}

                        {# APPROVED + PAID #}
                        {% if reservation.status == 'approved'
                            and reservation.paymentStatus == 'paid' %}

                            <form method="post"
                                  action="{{ path('app_reservation_complete', {'id': reservation.id}) }}">

                                <button class="btn btn-primary">
                                    🏁 Complete Reservation
                                </button>

                            </form>

                        {% endif %}

                    </div>

                </div>

                {# RIGHT SIDE #}
                <div class="col-lg-6">

                    <div class="mb-4">

                        <h5 class="mb-3">
                            Driver License
                        </h5>

                        {% if reservation.licenseImage %}

                            <img
                                src="{{ asset('uploads/licenses/' ~ reservation.licenseImage) }}"
                                class="img-fluid rounded border shadow-sm">

                        {% else %}

                            <div class="alert alert-secondary mb-0">
                                No license uploaded
                            </div>

                        {% endif %}

                    </div>

                    <div>

                        <h5 class="mb-3">
                            CIN Image
                        </h5>

                        {% if reservation.cinImage %}

                            <img
                                src="{{ asset('uploads/cin/' ~ reservation.cinImage) }}"
                                class="img-fluid rounded border shadow-sm">

                        {% else %}

                            <div class="alert alert-secondary mb-0">
                                No CIN uploaded
                            </div>

                        {% endif %}

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
