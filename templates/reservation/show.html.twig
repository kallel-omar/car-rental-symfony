{% extends 'admin/layout.html.twig' %}

{% block title %}Reservation Details{% endblock %}

{% block body %}

<style>

.details-card {
    border: none;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 8px 28px rgba(0,0,0,0.06);
}

.details-table th,
.details-table td {
    padding: 18px 22px !important;
    vertical-align: middle;
}

.details-table th {
    width: 35%;
    background: #f8f9fa;
    font-weight: 700;
    color: #111827;
}

.details-table td {
    font-weight: 500;
}

.image-box {
    background: white;
    border-radius: 22px;
    padding: 22px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.05);
    height: 100%;
}

.image-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 18px;
    color: #111827;
}

.document-image {
    width: 100%;
    border-radius: 18px;
    border: 1px solid #e9ecef;
    transition: 0.3s;
}

.document-image:hover {
    transform: scale(1.01);
}

.status-badge {
    padding: 9px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
}

.action-btn {
    border-radius: 50px;
    padding: 12px 22px;
    font-weight: 600;
}

.info-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0;
}

.section-subtitle {
    color: #6b7280;
    margin-top: 6px;
}

</style>

<div class="container py-5">

    {# HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">
                Reservation #{{ reservation.id }}
            </h1>

            <p class="section-subtitle mb-0">
                Reservation details and verification
            </p>

        </div>

        <a
            href="{{ path('app_reservation_index') }}"
            class="btn btn-outline-dark action-btn">

            ← Back

        </a>

    </div>

    <div class="card details-card">

        <div class="card-body p-4">

            <div class="row g-4">

                {# LEFT SIDE #}
                <div class="col-lg-6">

                    <div class="mb-4">

                        <h3 class="info-title">
                            Reservation Information
                        </h3>

                    </div>

                    <table class="table table-bordered align-middle details-table">

                        <tbody>

                            <tr>
                                <th>Customer</th>
                                <td>{{ reservation.fullName }}</td>
                            </tr>

                            <tr>
                                <th>Phone</th>
                                <td>{{ reservation.phoneNumber }}</td>
                            </tr>

                            <tr>
                                <th>User Email</th>
                                <td>{{ reservation.user.email }}</td>
                            </tr>

                            <tr>
                                <th>Car</th>

                                <td>

                                    <div class="fw-semibold">
                                        {{ reservation.car.brand }}
                                        {{ reservation.car.model }}
                                    </div>

                                </td>

                            </tr>

                            <tr>
                                <th>Start Date</th>

                                <td>
                                    {{ reservation.startDate|date('d M Y') }}
                                </td>

                            </tr>

                            <tr>
                                <th>End Date</th>

                                <td>
                                    {{ reservation.endDate|date('d M Y') }}
                                </td>

                            </tr>

                            <tr>
                                <th>Total Price</th>

                                <td class="fw-bold text-success">
                                    {{ reservation.totalPrice }} €
                                </td>

                            </tr>

                            {# PAYMENT #}
                            <tr>

                                <th>Payment</th>

                                <td>

                                    {% if reservation.paymentStatus == 'paid' %}

                                        <span class="badge bg-success status-badge">

                                            Paid

                                        </span>

                                    {% else %}

                                        <span class="badge bg-warning text-dark status-badge">

                                            Unpaid

                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                            {# LICENSE CHECK #}
                            <tr>

                                <th>License Check</th>

                                <td>

                                    {% if reservation.licenseIssueDate %}

                                        {% set difference = date().diff(reservation.licenseIssueDate) %}

                                        {% if difference.y >= 2 %}

                                            <span class="badge bg-success status-badge">

                                                ✅ Valid

                                            </span>

                                        {% else %}

                                            <span class="badge bg-danger status-badge">

                                                ❌ Invalid

                                            </span>

                                        {% endif %}

                                    {% else %}

                                        <span class="badge bg-secondary status-badge">

                                            N/A

                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                            {# STATUS #}
                            <tr>

                                <th>Status</th>

                                <td>

                                    {% if reservation.status == 'pending' %}

                                        <span class="badge bg-warning text-dark status-badge">

                                            Pending

                                        </span>

                                    {% elseif reservation.status == 'approved' %}

                                        <span class="badge bg-success status-badge">

                                            Approved

                                        </span>

                                    {% elseif reservation.status == 'rejected' %}

                                        <span class="badge bg-danger status-badge">

                                            Rejected

                                        </span>

                                    {% elseif reservation.status == 'completed' %}

                                        <span class="badge bg-primary status-badge">

                                            Completed

                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                        </tbody>

                    </table>

                    {# ACTION BUTTONS #}
                    <div class="d-flex gap-3 mt-4 flex-wrap">

                        {% if reservation.status == 'pending' %}

                            <form
                                method="post"
                                action="{{ path('app_reservation_approve', {'id': reservation.id}) }}">

                                <button class="btn btn-success action-btn">

                                    ✅ Approve

                                </button>

                            </form>

                            <form
                                method="post"
                                action="{{ path('app_reservation_reject', {'id': reservation.id}) }}">

                                <button class="btn btn-danger action-btn">

                                    ❌ Reject

                                </button>

                            </form>

                        {% endif %}

                        {% if reservation.status == 'approved'
                            and reservation.paymentStatus == 'unpaid' %}

                            <form
                                method="post"
                                action="{{ path('app_reservation_confirm_payment', {'id': reservation.id}) }}">

                                <button class="btn btn-warning text-dark action-btn">

                                    💵 Confirm Payment

                                </button>

                            </form>

                        {% endif %}

                        {% if reservation.status == 'approved'
                            and reservation.paymentStatus == 'paid' %}

                            <form
                                method="post"
                                action="{{ path('app_reservation_complete', {'id': reservation.id}) }}">

                                <button class="btn btn-primary action-btn">

                                    🏁 Complete Reservation

                                </button>

                            </form>

                        {% endif %}

                    </div>

                </div>

                {# RIGHT SIDE #}
                <div class="col-lg-6">

                    <div class="row g-4">

                        {# LICENSE IMAGE #}
                        <div class="col-12">

                            <div class="image-box">

                                <div class="image-title">

                                    Driver License

                                </div>

                                {% if reservation.licenseImage %}

                                    <img
                                        src="{{ asset('uploads/licenses/' ~ reservation.licenseImage) }}"
                                        class="document-image">

                                {% else %}

                                    <div class="alert alert-secondary mb-0">

                                        No license uploaded

                                    </div>

                                {% endif %}

                            </div>

                        </div>

                        {# CIN IMAGE #}
                        <div class="col-12">

                            <div class="image-box">

                                <div class="image-title">

                                    CIN Image

                                </div>

                                {% if reservation.cinImage %}

                                    <img
                                        src="{{ asset('uploads/cin/' ~ reservation.cinImage) }}"
                                        class="document-image">

                                {% else %}

                                    <div class="alert alert-secondary mb-0">

                                        No CIN uploaded

                                    </div>

                                {% endif %}

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
