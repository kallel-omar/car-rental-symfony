{% extends 'base.html.twig' %}

{% block title %}Reserve Your Car{% endblock %}

{% block body %}

<style>

body {
    background: #f8f9fa;
}

.reservation-hero {
    background: linear-gradient(135deg, #111827, #1f2937);
    border-radius: 0 0 40px 40px;
    padding: 90px 0 140px;
}

.hero-title {
    color: white;
    font-size: 3rem;
    font-weight: 800;
}

.hero-subtitle {
    color: rgba(255,255,255,0.7);
}

.reservation-wrapper {
    margin-top: -80px;
    position: relative;
    z-index: 10;
}

.reservation-card {
    background: white;
    border-radius: 32px;
    padding: 45px;
    box-shadow: 0 15px 45px rgba(0,0,0,0.08);
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

.form-control,
.form-select {
    border-radius: 18px;
    padding: 16px 18px;
    border: 1px solid #e5e7eb;
    background: #fcfcfc;
}

.form-control:focus,
.form-select:focus {
    border-color: #198754;
    box-shadow: 0 0 0 0.18rem rgba(25,135,84,.12);
}

.form-label {
    font-weight: 700;
    margin-bottom: 12px;
}

.reservation-btn {
    background: linear-gradient(135deg, #198754, #157347);
    border: none;
    border-radius: 18px;
    padding: 16px;
    width: 100%;
    color: white;
    font-weight: 700;
    margin-top: 25px;
    transition: 0.3s;
}

.reservation-btn:hover {
    transform: translateY(-2px);
    opacity: 0.95;
}

.document-preview {
    border-radius: 18px;
    border: 1px solid #dee2e6;
    max-height: 220px;
    object-fit: cover;
    width: 100%;
}

.document-box {
    background: #f8f9fa;
    border-radius: 24px;
    padding: 24px;
    border: 1px solid #e9ecef;
    height: 100%;
}

.document-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 18px;
}

.readonly-input {
    background: #eef2f7 !important;
    cursor: not-allowed;
    opacity: 0.9;
}

.flatpickr-input[readonly] {
    background: #eef2f7 !important;
}

@media(max-width:768px){

    .form-grid{
        grid-template-columns:1fr;
    }

    .reservation-card{
        padding:28px;
    }

    .hero-title{
        font-size:2.2rem;
    }
}

</style>

<section class="reservation-hero">

    <div class="container">

        <h1 class="hero-title">
            Reserve Your Dream Car
        </h1>

        <p class="hero-subtitle">
            Fast, secure and professional reservation experience.
        </p>

    </div>

</section>

<section class="reservation-wrapper">

    <div class="container">

        <div class="reservation-card">

            {{ form_start(form, {
                'attr': {
                    'enctype': 'multipart/form-data'
                }
            }) }}

            <div class="form-grid">

                {# CAR #}
                <div>

                    {{ form_label(form.car) }}

                    {{ form_widget(form.car, {
                        'attr': {
                            'class': 'form-select'
                        }
                    }) }}

                </div>

                {# FULL NAME #}
                <div>

                    {{ form_label(form.fullName) }}

                    {{ form_widget(form.fullName, {
                        'attr': {
                            'class': app.user.fullName
                                ? 'form-control readonly-input'
                                : 'form-control',

                            'readonly': app.user.fullName
                                ? true
                                : false
                        },
                        'value': app.user.fullName ?: ''
                    }) }}

                </div>

                {# PHONE #}
                <div>

                    {{ form_label(form.phoneNumber) }}

                    {{ form_widget(form.phoneNumber, {
                        'attr': {
                            'class': app.user.phoneNumber
                                ? 'form-control readonly-input'
                                : 'form-control',

                            'readonly': app.user.phoneNumber
                                ? true
                                : false
                        },
                        'value': app.user.phoneNumber ?: ''
                    }) }}

                </div>

                {# LICENSE DATE #}
                <div>

                    {{ form_label(form.licenseIssueDate) }}

                    {{ form_widget(form.licenseIssueDate, {
                        'attr': {
                            'class': app.user.licenseIssueDate
                                ? 'form-control readonly-input'
                                : 'form-control'
                        },
                        'value': app.user.licenseIssueDate
                            ? app.user.licenseIssueDate|date('Y-m-d')
                            : ''
                    }) }}

                </div>

                {# START DATE #}
                <div>

                    {{ form_label(form.startDate) }}

                    {{ form_widget(form.startDate, {
                        'attr': {
                            'class': 'form-control',
                            'autocomplete': 'off'
                        }
                    }) }}

                </div>

                {# END DATE #}
                <div>

                    {{ form_label(form.endDate) }}

                    {{ form_widget(form.endDate, {
                        'attr': {
                            'class': 'form-control',
                            'autocomplete': 'off'
                        }
                    }) }}

                </div>

            </div>

            {# DOCUMENTS #}
            <div class="row mt-4">

                {# CIN IMAGE #}
                <div class="col-lg-6 mb-4">

                    <div class="document-box">

                        <div class="document-title">

                            CIN Document

                        </div>

                        {% if app.user.cinImage %}

                            <div class="mb-3">

                                <img
                                    src="{{ asset('uploads/cin/' ~ app.user.cinImage) }}"
                                    class="document-preview"
                                >

                            </div>

                            <div class="alert alert-success border-0 rounded-4 mb-0">

                                ✅ CIN already uploaded

                            </div>

                        {% else %}

                            {{ form_label(form.cinImage) }}

                            {{ form_widget(form.cinImage, {
                                'attr': {
                                    'class': 'form-control'
                                }
                            }) }}

                        {% endif %}

                    </div>

                </div>

                {# LICENSE IMAGE #}
                <div class="col-lg-6 mb-4">

                    <div class="document-box">

                        <div class="document-title">

                            Driver License

                        </div>

                        {% if app.user.licenseImage %}

                            <div class="mb-3">

                                <img
                                    src="{{ asset('uploads/licenses/' ~ app.user.licenseImage) }}"
                                    class="document-preview"
                                >

                            </div>

                            <div class="alert alert-success border-0 rounded-4 mb-0">

                                ✅ License already uploaded

                            </div>

                        {% else %}

                            {{ form_label(form.licenseImage) }}

                            {{ form_widget(form.licenseImage, {
                                'attr': {
                                    'class': 'form-control'
                                }
                            }) }}

                        {% endif %}

                    </div>

                </div>

            </div>

            <button type="submit" class="reservation-btn">

                Confirm Reservation

            </button>

           {{ form_row(form._token) }}

           {{ form_end(form, {'render_rest': false}) }}

        </div>

    </div>

</section>

<script>

document.addEventListener('DOMContentLoaded', async function () {

    const carField = document.getElementById('reservation_car');

    let startPicker;
    let endPicker;

    async function loadDisabledDates(carId) {

        if (!carId) {
            return [];
        }

        const response = await fetch('/reservation/disabled-dates/' + carId);

        return await response.json();
    }

    async function initCalendars(carId) {

        const disabledDates = await loadDisabledDates(carId);

        if (startPicker) {
            startPicker.destroy();
        }

        if (endPicker) {
            endPicker.destroy();
        }

        // START DATE
        startPicker = flatpickr("#reservation_startDate", {

            dateFormat: "Y-m-d",

            minDate: "today",

            disable: disabledDates,

            onChange: function(selectedDates) {

                if (selectedDates.length > 0) {

                    let nextDay = new Date(selectedDates[0]);

                    nextDay.setDate(nextDay.getDate() + 1);

                    endPicker.set('minDate', nextDay);
                }
            }
        });

        // END DATE
        endPicker = flatpickr("#reservation_endDate", {

            dateFormat: "Y-m-d",

            minDate: "today",

            disable: disabledDates
        });
    }

    // FIRST LOAD
    if (carField.value) {

        await initCalendars(carField.value);
    }

    // CAR CHANGE
    carField.addEventListener('change', async function () {

        await initCalendars(this.value);
    });

});

</script>

{% endblock %}
