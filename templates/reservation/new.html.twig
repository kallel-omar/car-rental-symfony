{% extends 'base.html.twig' %}

{% block title %}New Reservation{% endblock %}

{% block body %}

<div class="container mt-5">

    <div class="card shadow-sm p-4">

        <h3 class="mb-4">Reservation Details</h3>

        {{ form_start(form, {
            'attr': {
                'enctype': 'multipart/form-data'
            }
        }) }}

        <div class="mb-3">
            {{ form_label(form.car) }}
            {{ form_widget(form.car, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.car) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.fullName) }}
            {{ form_widget(form.fullName, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.fullName) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.phoneNumber) }}
            {{ form_widget(form.phoneNumber, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.phoneNumber) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.startDate) }}
            {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.startDate) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.endDate) }}
            {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.endDate) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.licenseIssueDate) }}
            {{ form_widget(form.licenseIssueDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.licenseIssueDate) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.cinImage) }}
            {{ form_widget(form.cinImage, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.cinImage) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.licenseImage) }}
            {{ form_widget(form.licenseImage, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.licenseImage) }}
        </div>

        <button type="submit" class="btn btn-success w-100 mt-3">
            🚗 Confirm Reservation
        </button>

        {{ form_end(form) }}

    </div>

</div>

{% endblock %}
