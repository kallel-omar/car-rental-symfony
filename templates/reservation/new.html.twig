{% extends 'base.html.twig' %}

{% block title %}Reserve Your Car{% endblock %}

{% block body %}

<section class="reservation-form-hero">

    <div class="container">

        <h1 class="reservation-form-title">
            Reserve Your Dream Car
        </h1>

        <p class="reservation-form-subtitle">
            Fast, secure and professional reservation experience.
        </p>

    </div>

</section>

<section class="reservation-form-wrapper">

    <div class="container">

        <div class="reservation-form-card">

            {{ form_start(form, {
                'attr': {
                    'enctype': 'multipart/form-data'
                }
            }) }}

            <div class="reservation-form-grid">

                <div>
                    {{ form_label(form.car) }}
                    {{ form_widget(form.car, {'attr': {'class': 'form-select'}}) }}
                </div>

                <div>
                    {{ form_label(form.fullName) }}
                    {{ form_widget(form.fullName, {
                        'attr': {
                            'class': app.user.fullName ? 'form-control readonly-input' : 'form-control',
                            'readonly': app.user.fullName ? true : false
                        },
                        'value': app.user.fullName ?: ''
                    }) }}
                </div>

                <div>
                    {{ form_label(form.phoneNumber) }}
                    {{ form_widget(form.phoneNumber, {
                        'attr': {
                            'class': app.user.phoneNumber ? 'form-control readonly-input' : 'form-control',
                            'readonly': app.user.phoneNumber ? true : false
                        },
                        'value': app.user.phoneNumber ?: ''
                    }) }}
                </div>

                <div>
                    {{ form_label(form.licenseIssueDate) }}
                    {{ form_widget(form.licenseIssueDate, {
                        'attr': {
                            'class': app.user.licenseIssueDate ? 'form-control readonly-input' : 'form-control'
                        },
                        'value': app.user.licenseIssueDate ? app.user.licenseIssueDate|date('Y-m-d') : ''
                    }) }}
                </div>

                <div>
                    {{ form_label(form.startDate) }}
                    {{ form_widget(form.startDate, {
                        'attr': {
                            'class': 'form-control',
                            'autocomplete': 'off'
                        }
                    }) }}
                </div>

                <div>
                    {{ form_label(form.endDate) }}
                    {{ form_widget(form.endDate, {
                        'attr': {
                            'class': 'form-control',
                            'autocomplete': 'off'
                        }
                    }) }}
                </div>

            </div>

            <div class="row mt-4">

                <div class="col-lg-6 mb-4">

                    <div class="reservation-document-box">

                        <div class="reservation-document-title">
                            CIN Document
                        </div>

                        {% if app.user.cinImage %}

                            <div class="mb-3">
                                <img
                                    src="{{ asset('uploads/cin/' ~ app.user.cinImage) }}"
                                    class="reservation-document-preview">
                            </div>

                            <div class="alert alert-success border-0 rounded-4 mb-0">
                                ✅ CIN already uploaded
                            </div>

                        {% else %}

                            {{ form_label(form.cinImage) }}
                            {{ form_widget(form.cinImage, {'attr': {'class': 'form-control'}}) }}

                        {% endif %}

                    </div>

                </div>

                <div class="col-lg-6 mb-4">

                    <div class="reservation-document-box">

                        <div class="reservation-document-title">
                            Driver License
                        </div>

                        {% if app.user.licenseImage %}

                            <div class="mb-3">
                                <img
                                    src="{{ asset('uploads/licenses/' ~ app.user.licenseImage) }}"
                                    class="reservation-document-preview">
                            </div>

                            <div class="alert alert-success border-0 rounded-4 mb-0">
                                ✅ License already uploaded
                            </div>

                        {% else %}

                            {{ form_label(form.licenseImage) }}
                            {{ form_widget(form.licenseImage, {'attr': {'class': 'form-control'}}) }}

                        {% endif %}

                    </div>

                </div>

            </div>

            <button type="submit" class="reservation-submit-btn">
                Confirm Reservation
            </button>

            {{ form_row(form._token) }}

            {{ form_end(form, {'render_rest': false}) }}

        </div>

    </div>

</section>

<script>
document.addEventListener('DOMContentLoaded', async function () {

    const carField = document.getElementById('reservation_car');

    let startPicker;
    let endPicker;

    async function loadDisabledDates(carId) {
        if (!carId) {
            return [];
        }

        const response = await fetch('/reservation/disabled-dates/' + carId);
        return await response.json();
    }

    async function initCalendars(carId) {
        const disabledDates = await loadDisabledDates(carId);

        if (startPicker) {
            startPicker.destroy();
        }

        if (endPicker) {
            endPicker.destroy();
        }

        startPicker = flatpickr("#reservation_startDate", {
            dateFormat: "Y-m-d",
            minDate: "today",
            disable: disabledDates,
            onChange: function(selectedDates) {
                if (selectedDates.length > 0) {
                    let nextDay = new Date(selectedDates[0]);
                    nextDay.setDate(nextDay.getDate() + 1);
                    endPicker.set('minDate', nextDay);
                }
            }
        });

        endPicker = flatpickr("#reservation_endDate", {
            dateFormat: "Y-m-d",
            minDate: "today",
            disable: disabledDates
        });
    }

    if (carField.value) {
        await initCalendars(carField.value);
    }

    carField.addEventListener('change', async function () {
        await initCalendars(this.value);
    });

});
</script>

{% endblock %}
