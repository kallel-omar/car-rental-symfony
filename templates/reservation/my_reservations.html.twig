{% extends 'base.html.twig' %}

{% block title %}My Reservations{% endblock %}

{% block body %}

<style>

body {
    background: #f8f9fa;
}

.hero-section {
    background: linear-gradient(135deg, #111827, #1f2937);
    padding: 90px 0 140px;
    border-radius: 0 0 40px 40px;
}

.hero-title {
    color: white;
    font-size: 3rem;
    font-weight: 800;
}

.hero-subtitle {
    color: rgba(255,255,255,0.7);
    margin-top: 10px;
    font-size: 17px;
}

.reservations-wrapper {
    margin-top: -90px;
    position: relative;
    z-index: 10;
}

.reservation-card {
    background: white;
    border-radius: 28px;
    padding: 28px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
    margin-bottom: 28px;
    transition: 0.25s ease;
}

.reservation-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 45px rgba(0,0,0,0.12);
}

.car-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 5px;
}

.reservation-id {
    color: #6b7280;
    font-size: 14px;
}

.info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-top: 28px;
}

.info-box {
    background: #f9fafb;
    border-radius: 18px;
    padding: 18px;
}

.info-label {
    font-size: 13px;
    font-weight: 700;
    color: #6b7280;
    margin-bottom: 8px;
}

.info-value {
    font-weight: 700;
    color: #111827;
}

.price-text {
    color: #198754;
    font-size: 1.4rem;
    font-weight: 800;
}

.status-badge {
    display: inline-block;
    padding: 10px 18px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
}

.pending {
    background: #fff3cd;
    color: #856404;
}

.approved {
    background: #d1e7dd;
    color: #146c43;
}

.rejected {
    background: #f8d7da;
    color: #842029;
}

.completed {
    background: #cfe2ff;
    color: #084298;
}

.invoice-btn {
    display: inline-block;
    margin-top: 25px;
    background: #111827;
    color: white;
    padding: 13px 22px;
    border-radius: 16px;
    text-decoration: none;
    font-weight: 700;
    transition: 0.25s ease;
}

.invoice-btn:hover {
    background: black;
    color: white;
    transform: translateY(-2px);
}

.disabled-btn {
    background: #e5e7eb;
    color: #6b7280;
    cursor: not-allowed;
}

.empty-box {
    background: white;
    border-radius: 28px;
    padding: 80px 30px;
    text-align: center;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
}

.empty-icon {
    font-size: 4rem;
    margin-bottom: 20px;
}

.empty-title {
    font-size: 1.7rem;
    font-weight: 800;
    color: #111827;
}

.empty-text {
    color: #6b7280;
    margin-top: 10px;
}

</style>

<section class="hero-section">

    <div class="container">

        <h1 class="hero-title">

            My Reservations

        </h1>

        <p class="hero-subtitle">

            Track your reservations and invoices easily.

        </p>

    </div>

</section>

<section class="reservations-wrapper">

    <div class="container">

        {% for reservation in reservations %}

            <div class="reservation-card">

                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                    <div>

                        <div class="car-title">

                            {{ reservation.car.brand }}
                            {{ reservation.car.model }}

                        </div>

                        <div class="reservation-id">

                            Reservation #{{ reservation.id }}

                        </div>

                    </div>

                    <div>

                        {% if reservation.status == 'pending' %}

                            <span class="status-badge pending">

                                Pending

                            </span>

                        {% elseif reservation.status == 'approved' %}

                            <span class="status-badge approved">

                                Approved

                            </span>

                        {% elseif reservation.status == 'rejected' %}

                            <span class="status-badge rejected">

                                Rejected

                            </span>

                        {% elseif reservation.status == 'completed' %}

                            <span class="status-badge completed">

                                Completed

                            </span>

                        {% endif %}

                    </div>

                </div>

                <div class="info-grid">

                    <div class="info-box">

                        <div class="info-label">

                            Start Date

                        </div>

                        <div class="info-value">

                            {{ reservation.startDate|date('d M Y') }}

                        </div>

                    </div>

                    <div class="info-box">

                        <div class="info-label">

                            End Date

                        </div>

                        <div class="info-value">

                            {{ reservation.endDate|date('d M Y') }}

                        </div>

                    </div>

                    <div class="info-box">

                        <div class="info-label">

                            Total Price

                        </div>

                        <div class="price-text">

                            {{ reservation.totalPrice }} €

                        </div>

                    </div>

                </div>

                {% if reservation.status in ['approved', 'completed'] %}

                    <a href="{{ path('app_reservation_invoice', {'id': reservation.id}) }}"
                       class="invoice-btn">

                        Download Invoice

                    </a>

                {% else %}

                    <span class="invoice-btn disabled-btn">

                        Invoice Unavailable

                    </span>

                {% endif %}

            </div>

        {% else %}

            <div class="empty-box">

                <div class="empty-icon">

                    🚘

                </div>

                <h3 class="empty-title">

                    No Reservations Yet

                </h3>

                <p class="empty-text">

                    Your reservations will appear here once you book a car.

                </p>

            </div>

        {% endfor %}

    </div>

</section>

{% endblock %}
