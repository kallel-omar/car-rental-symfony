{% extends 'base.html.twig' %}

{% block title %}My Reservations{% endblock %}

{% block body %}

<section class="reservations-hero">

    <div class="container">

        <h1 class="reservations-hero-title">
            My Reservations
        </h1>

        <p class="reservations-hero-subtitle">
            Track your reservations and invoices easily.
        </p>

    </div>

</section>

<section class="reservations-wrapper">

    <div class="container">

        {% for reservation in reservations %}

            <div class="my-reservation-card">

                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                    <div>

                        <div class="reservation-car-title">


                            {{ reservation.car.model }}
                            {{ reservation.car.registrationNumber }}

                        </div>

                        <div class="reservation-id">

                            Reservation #{{ reservation.id }}

                        </div>

                    </div>

                    <div>

                        {% if reservation.status == 'pending' %}

                            <span class="status-badge pending">
                                Pending
                            </span>

                        {% elseif reservation.status == 'approved' %}

                            <span class="status-badge approved">
                                Approved
                            </span>

                        {% elseif reservation.status == 'rejected' %}

                            <span class="status-badge rejected">
                                Rejected
                            </span>

                        {% elseif reservation.status == 'completed' %}

                            <span class="status-badge completed">
                                Completed
                            </span>

                        {% endif %}

                    </div>

                </div>

                <div class="reservation-info-grid">

                    <div class="reservation-info-box">

                        <div class="reservation-info-label">
                            Start Date
                        </div>

                        <div class="reservation-info-value">
                            {{ reservation.startDate|date('d M Y') }}
                        </div>

                    </div>

                    <div class="reservation-info-box">

                        <div class="reservation-info-label">
                            End Date
                        </div>

                        <div class="reservation-info-value">
                            {{ reservation.endDate|date('d M Y') }}
                        </div>

                    </div>

                    <div class="reservation-info-box">

                        <div class="reservation-info-label">
                            Total Price
                        </div>

                        <div class="reservation-price">
                            {{ reservation.totalPrice }} €
                        </div>

                    </div>

                </div>

                {% if reservation.status in ['approved', 'completed'] %}

                    <a href="{{ path('app_reservation_invoice', {'id': reservation.id}) }}"
                       class="invoice-btn">

                        Download Invoice

                    </a>

                {% else %}

                    <span class="invoice-btn disabled-btn">

                        Invoice Unavailable

                    </span>

                {% endif %}

            </div>

        {% else %}

            <div class="reservations-empty-box">

                <div class="reservations-empty-icon">
                    🚘
                </div>

                <h3 class="reservations-empty-title">
                    No Reservations Yet
                </h3>

                <p class="reservations-empty-text">
                    Your reservations will appear here once you book a car.
                </p>

            </div>

        {% endfor %}

    </div>

</section>

{% endblock %}
