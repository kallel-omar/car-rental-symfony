{% extends 'admin/layout.html.twig' %}

{% block title %}Reservations{% endblock %}

{% block body %}



<div class="container py-5">

    {# HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-2">Reservations</h1>

            <p class="text-muted mb-2">
                Manage all customer reservations
            </p>

        <a class="btn btn-primary shadow-sm px-4"
                           href="{{ path('app_reservation_new') }}">

                            + New Reservation

                        </a>

        </div>

    <form method="get" class="d-flex gap-2 mb-4">

        {% if currentStatus %}
            <input
                type="hidden"
                name="status"
                value="{{ currentStatus }}">
        {% endif %}

        <input
            type="text"
            name="search"
            value="{{ search }}"
            class="form-control rounded-pill px-4"
            placeholder="Search by customer, email, phone, brand or model">

        <button class="btn btn-dark rounded-pill px-4">

            Search

        </button>

    </form>



    </div>

    {# TABLE CARD #}
    <div class="card border-0 shadow-sm">

        <div class="d-flex gap-2 flex-wrap mb-4 p-4 pb-0">

            <a href="{{ path('app_reservation_index') }}"
               class="btn btn-dark">

                All

            </a>

            <a href="{{ path('app_reservation_index', {'status': 'pending'}) }}"
               class="btn btn-warning text-dark">

                Pending

            </a>

           <a
               href="{{ path('app_reservation_index', {'status': 'waiting_pickup'}) }}"
               class="btn  px-4"
               style="background:#f59e0b;color:white;">

               Waiting Pickup

           </a>

           <a
               href="{{ path('app_reservation_index', {'status': 'picked_up'}) }}"
               class="btn  bg-info text-dark "
               style="background:#dbeafe;color:white;">

               Picked Up

           </a>

            <a href="{{ path('app_reservation_index', {'status': 'completed'}) }}"
               class="btn btn-primary">

                Completed

            </a>

            <a href="{{ path('app_reservation_index', {'status': 'rejected'}) }}"
               class="btn btn-danger">

                Rejected

            </a>


        </div>

        <div class="card-body p-4">

            <div class="table-responsive p-2">

                <table class="table table-hover align-middle mb-0 custom-table">

                    <thead class="table-dark">

                        <tr>

                            <th>Customer</th>
                            <th>Phone</th>
                            <th>Car</th>
                            <th>Reservation Dates</th>
                            <th>License Check</th>
                            <th>Total</th>
                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                    {% for reservation in reservations %}

                        <tr>

                            {# CUSTOMER #}
                            <td>

                                <div class="fw-semibold">

                                    {{ reservation.user.fullName ?: 'No Name' }}

                                </div>

                            </td>

                            {# PHONE #}
                            <td>

                                {{ reservation.user.phoneNumber ?: 'No Phone' }}

                            </td>

                            {# CAR #}
                            <td>

                                <div class="fw-semibold">

                                    {{ reservation.car ? reservation.car.brand : 'N/A' }}

                                </div>

                                <small class="text-muted">

                                    {{ reservation.car ? reservation.car.model : '' }}

                                </small>

                            </td>

                            {# RESERVATION DATES #}
                            <td>

                                <div>

                                    <strong>From:</strong>

                                    {{ reservation.startDate
                                        ? reservation.startDate|date('d M Y')
                                        : ''
                                    }}

                                </div>

                                <div>

                                    <strong>To:</strong>

                                    {{ reservation.endDate
                                        ? reservation.endDate|date('d M Y')
                                        : ''
                                    }}

                                </div>

                            </td>

                            {# LICENSE VALIDATION #}
                            <td>

                                {% if reservation.user.licenseIssueDate %}

                                    {% set difference = date().diff(reservation.user.licenseIssueDate) %}

                                    {% if difference.y >= 2 %}

                                        <span class="badge rounded-pill bg-success px-3 py-2">

                                            ✅ OK

                                        </span>

                                    {% else %}

                                        <span class="badge rounded-pill bg-danger px-3 py-2">

                                            ❌ Not OK

                                        </span>

                                    {% endif %}

                                {% else %}

                                    <span class="badge rounded-pill bg-secondary px-3 py-2">

                                        N/A

                                    </span>

                                {% endif %}

                            </td>

                            {# TOTAL PRICE #}
                            <td class="fw-bold text-success">

                                {{ reservation.totalPrice }} €

                            </td>

                            {# STATUS #}
                           <td>

                               {% set buttonClass = 'btn-secondary' %}
                               {% set buttonStyle = '' %}
                               {% set buttonText = 'N/A' %}

                               {% if reservation.status == 'pending' %}

                                   {% set buttonClass = 'btn-warning text-dark' %}
                                   {% set buttonText = 'Pending' %}

                               {% elseif reservation.status == 'approved' %}

                                   {% if reservation.rentalProcesses|length > 0
                                       and reservation.rentalProcesses.first.status == 'waiting_pickup' %}

                                       {% set buttonClass = 'btn' %}
                                       {% set buttonStyle = 'background:#f59e0b;color:white;' %}
                                       {% set buttonText = 'Waiting Pickup' %}

                                   {% elseif reservation.rentalProcesses|length > 0
                                       and reservation.rentalProcesses.first.status == 'picked_up' %}

                                       {% set buttonClass = 'btn  bg-info text-dark ' %}
                                       {% set buttonStyle = 'background:#f59e0b;color:white;' %}
                                       {% set buttonText = 'Picked Up' %}

                                   {% else %}

                                       {% set buttonClass = 'btn-success' %}
                                       {% set buttonText = 'Approved' %}

                                   {% endif %}

                               {% elseif reservation.status == 'rejected' %}

                                   {% set buttonClass = 'btn-danger' %}
                                   {% set buttonText = 'Rejected' %}

                               {% elseif reservation.status == 'completed' %}

                                   {% set buttonClass = 'btn-primary' %}
                                   {% set buttonText = 'Completed' %}

                               {% endif %}

                               <a
                                   href="{{ path('app_reservation_show', {'id': reservation.id}) }}"
                                   class="btn btn-sm w-100 {{ buttonClass }}"
                                   style="{{ buttonStyle }}">

                                   {{ buttonText }}

                               </a>

                           </td>

                        </tr>

                    {% else %}

                        <tr>

                            <td colspan="12"
                                class="text-center py-5 text-muted">

                                <h5>No reservations found</h5>

                            </td>

                        </tr>

                    {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

{% endblock %}
