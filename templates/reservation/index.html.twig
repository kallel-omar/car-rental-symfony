{% extends 'admin/layout.html.twig' %}

{% block title %}Reservations{% endblock %}

{% block body %}

<style>

.custom-table th,
.custom-table td {
    padding: 20px 25px !important;
    vertical-align: middle;
}

.custom-table thead th {
    white-space: nowrap;
}

.custom-table tbody tr:hover {
    background-color: #f8f9fa;
    transition: 0.2s;
}

</style>

<div class="container py-5">

    {# HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">Reservations</h1>

            <p class="text-muted mb-0">
                Manage all customer reservations
            </p>
        </div>

        <a class="btn btn-success shadow-sm px-4"
           href="{{ path('app_reservation_new') }}">

            + New Reservation

        </a>

    </div>

    {# TABLE CARD #}
    <div class="card border-0 shadow-sm">

        <div class="d-flex gap-2 flex-wrap mb-4 p-4 pb-0">

            <a href="{{ path('app_reservation_index') }}"
               class="btn btn-dark">

                All

            </a>

            <a href="{{ path('app_reservation_index', {'status': 'pending'}) }}"
               class="btn btn-warning text-dark">

                Pending

            </a>

            <a href="{{ path('app_reservation_index', {'status': 'approved'}) }}"
               class="btn btn-success">

                Approved

            </a>

            <a href="{{ path('app_reservation_index', {'status': 'completed'}) }}"
               class="btn btn-primary">

                Completed

            </a>

            <a href="{{ path('app_reservation_index', {'status': 'rejected'}) }}"
               class="btn btn-danger">

                Rejected

            </a>

        </div>

        <div class="card-body p-4">

            <div class="table-responsive p-2">

                <table class="table table-hover align-middle mb-0 custom-table">

                    <thead class="table-dark">

                        <tr>

                            <th>Customer</th>
                            <th>Phone</th>
                            <th>Car</th>
                            <th>Reservation Dates</th>
                            <th>License Check</th>
                            <th>Total</th>
                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                    {% for reservation in reservations %}

                        <tr>

                            {# CUSTOMER #}
                            <td>

                                <div class="fw-semibold">

                                    {{ reservation.user.fullName ?: 'No Name' }}

                                </div>

                            </td>

                            {# PHONE #}
                            <td>

                                {{ reservation.user.phoneNumber ?: 'No Phone' }}

                            </td>

                            {# CAR #}
                            <td>

                                <div class="fw-semibold">

                                    {{ reservation.car ? reservation.car.brand : 'N/A' }}

                                </div>

                                <small class="text-muted">

                                    {{ reservation.car ? reservation.car.model : '' }}

                                </small>

                            </td>

                            {# RESERVATION DATES #}
                            <td>

                                <div>

                                    <strong>From:</strong>

                                    {{ reservation.startDate
                                        ? reservation.startDate|date('d M Y')
                                        : ''
                                    }}

                                </div>

                                <div>

                                    <strong>To:</strong>

                                    {{ reservation.endDate
                                        ? reservation.endDate|date('d M Y')
                                        : ''
                                    }}

                                </div>

                            </td>

                            {# LICENSE VALIDATION #}
                            <td>

                                {% if reservation.user.licenseIssueDate %}

                                    {% set difference = date().diff(reservation.user.licenseIssueDate) %}

                                    {% if difference.y >= 2 %}

                                        <span class="badge rounded-pill bg-success px-3 py-2">

                                            ✅ OK

                                        </span>

                                    {% else %}

                                        <span class="badge rounded-pill bg-danger px-3 py-2">

                                            ❌ Not OK

                                        </span>

                                    {% endif %}

                                {% else %}

                                    <span class="badge rounded-pill bg-secondary px-3 py-2">

                                        N/A

                                    </span>

                                {% endif %}

                            </td>

                            {# TOTAL PRICE #}
                            <td class="fw-bold text-success">

                                {{ reservation.totalPrice }} €

                            </td>

                            {# STATUS #}
                            <td>

                                <a
                                    href="{{ path('app_reservation_show', {'id': reservation.id}) }}"
                                    class="
                                        btn btn-sm w-100

                                        {% if reservation.status == 'pending' %}
                                            btn-warning text-dark

                                        {% elseif reservation.status == 'approved' %}
                                            btn-success

                                        {% elseif reservation.status == 'rejected' %}
                                            btn-danger

                                        {% elseif reservation.status == 'completed' %}
                                            btn-primary

                                        {% else %}
                                            btn-secondary
                                        {% endif %}
                                    "
                                >

                                    {% if reservation.status == 'pending' %}

                                        Pending

                                    {% elseif reservation.status == 'approved' %}

                                        Approved

                                    {% elseif reservation.status == 'rejected' %}

                                        Rejected

                                    {% elseif reservation.status == 'completed' %}

                                        Completed

                                    {% else %}

                                        N/A

                                    {% endif %}

                                </a>

                            </td>

                        </tr>

                    {% else %}

                        <tr>

                            <td colspan="12"
                                class="text-center py-5 text-muted">

                                <h5>No reservations found</h5>

                            </td>

                        </tr>

                    {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

{% endblock %}
