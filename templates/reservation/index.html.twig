{% extends 'base.html.twig' %}

{% block title %}Reservations{% endblock %}

{% block body %}
<h1>Reservations List</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Car</th>
            <th>User</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Total Price</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
    {% for reservation in reservations %}
        <tr>
            <td>{{ reservation.id }}</td>

            <td>
                {{ reservation.car ? reservation.car.model : 'N/A' }}
            </td>

            <td>
                {{ reservation.user ? reservation.user.email : 'N/A' }}
            </td>

            <td>
                {{ reservation.startDate ? reservation.startDate|date('Y-m-d') : '' }}
            </td>

            <td>
                {{ reservation.endDate ? reservation.endDate|date('Y-m-d') : '' }}
            </td>

            <td>
                {{ reservation.totalPrice }} €
            </td>

            <td>
                {% if reservation.status == 'pending' %}
                    <span class="badge bg-warning text-dark">Pending</span>
                {% elseif reservation.status == 'confirmed' %}
                    <span class="badge bg-success">Confirmed</span>
                {% elseif reservation.status == 'cancelled' %}
                    <span class="badge bg-danger">Cancelled</span>
                {% else %}
                    <span class="badge bg-secondary">N/A</span>
                {% endif %}
            </td>

            <td>
                <a class="btn btn-sm btn-primary"
                   href="{{ path('app_reservation_show', {'id': reservation.id}) }}">
                    Show
                </a>

                <a class="btn btn-sm btn-warning"
                   href="{{ path('app_reservation_edit', {'id': reservation.id}) }}">
                    Edit
                </a>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="8">No reservations found</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<a class="btn btn-success" href="{{ path('app_reservation_new') }}">
    Create New Reservation
</a>

{% endblock %}
