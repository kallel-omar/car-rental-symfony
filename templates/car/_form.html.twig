{{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

<div class="row g-4">

    <div class="col-md-6">
        <div class="form-group-modern">
            {{ form_label(form.brand) }}
            {{ form_widget(form.brand, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.brand) }}
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group-modern">
            {{ form_label(form.model) }}
            {{ form_widget(form.model, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.model) }}
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group-modern">
            {{ form_label(form.pricePerDay) }}
            {{ form_widget(form.pricePerDay, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.pricePerDay) }}
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group-modern">
            {{ form_label(form.registrationNumber) }}
            {{ form_widget(form.registrationNumber, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.registrationNumber) }}
        </div>
    </div>

    <div class="col-md-4">
        <div class="form-group-modern">
            {{ form_label(form.year) }}
            {{ form_widget(form.year, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.year) }}
        </div>
    </div>

    <div class="col-md-4">
        <div class="form-group-modern">
            {{ form_label(form.transmission) }}
            {{ form_widget(form.transmission, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.transmission) }}
        </div>
    </div>

    <div class="col-md-4">
        <div class="form-group-modern">
            {{ form_label(form.fuelType) }}
            {{ form_widget(form.fuelType, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.fuelType) }}
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group-modern">
            {{ form_label(form.seats) }}
            {{ form_widget(form.seats, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.seats) }}
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group-modern">
            {{ form_label(form.image) }}
            {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.image) }}
        </div>
    </div>

    <div class="col-12">
        <div class="form-group-modern">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {
                'attr': {
                    'class': 'form-control',
                    'rows': 5
                }
            }) }}
            {{ form_errors(form.description) }}
        </div>
    </div>

</div>

<div class="mt-4 mb-4">

    <label class="form-label fw-bold">
        Status
    </label>

    <div class="d-flex gap-3 flex-wrap">

        <label class="status-option available-option">

            {{ form_widget(form.status.children[0], {
                'attr': {'class': 'form-check-input me-2'}
            }) }}

            Available

        </label>

        <label class="status-option unavailable-option">

            {{ form_widget(form.status.children[1], {
                'attr': {'class': 'form-check-input me-2'}
            }) }}

            Unavailable

        </label>

    </div>

    {{ form_errors(form.status) }}

</div>

<div class="d-flex justify-content-end">

    <button class="btn btn-success rounded-pill px-4 py-2 fw-semibold">
        {{ button_label|default('Save') }}
    </button>

</div>

{{ form_end(form) }}
