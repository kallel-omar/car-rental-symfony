{% extends 'base.html.twig' %}

{% block title %}
    {{ car.brand }} {{ car.model }}
{% endblock %}

{% block body %}

<style>

body {
    background: #f8f9fa;
}

.car-hero {
    background: linear-gradient(135deg, #111827, #1f2937);
    padding: 90px 0 140px;
    border-radius: 0 0 40px 40px;
    position: relative;
    overflow: hidden;
}

.car-hero::before {
    content: "";
    position: absolute;
    width: 420px;
    height: 420px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    top: -140px;
    right: -120px;
}

.hero-title {
    color: white;
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 12px;
}

.hero-subtitle {
    color: rgba(255,255,255,0.7);
    font-size: 17px;
}

.car-page {
    margin-top: -80px;
    margin-bottom: 80px;
    position: relative;
    z-index: 10;
}

.car-container {
    background: #ffffff;
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 15px 45px rgba(0,0,0,0.08);
}

.car-image {
    width: 100%;
    height: 100%;
    min-height: 620px;
    object-fit: cover;
}

.car-content {
    padding: 50px;
}

.car-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 24px;
}

.badge-available {
    background: #d1fae5;
    color: #065f46;
}

.badge-unavailable {
    background: #fee2e2;
    color: #991b1b;
}

.car-title {
    font-size: 2.8rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 10px;
}

.car-subtitle {
    color: #6b7280;
    font-size: 16px;
    margin-bottom: 35px;
}

.info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
}

.info-card {
    background: #f8f9fa;
    border-radius: 20px;
    padding: 22px;
    transition: 0.25s ease;
}

.info-card:hover {
    transform: translateY(-3px);
    background: #f1f3f5;
}

.info-label {
    display: block;
    color: #6c757d;
    font-size: 14px;
    margin-bottom: 10px;
}

.info-value {
    font-size: 18px;
    font-weight: 700;
    color: #111827;
}

.price-box {
    background: linear-gradient(135deg, #111827, #1f2937);
    color: white;
    border-radius: 24px;
    padding: 28px;
    margin-bottom: 35px;
}

.price-label {
    font-size: 14px;
    opacity: 0.7;
}

.price-value {
    font-size: 2.3rem;
    font-weight: 800;
}

.description-box {
    background: #f8f9fa;
    border-radius: 22px;
    padding: 28px;
    line-height: 1.9;
    color: #495057;
    margin-bottom: 35px;
}

.action-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
}

.custom-btn {
    border-radius: 16px;
    padding: 15px 24px;
    font-weight: 700;
    transition: 0.25s ease;
    border: none;
}

.book-btn {
    background: linear-gradient(135deg, #198754, #157347);
    color: white;
    flex: 1;
}

.book-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(25,135,84,0.25);
    color: white;
}

.back-btn {
    background: white;
    border: 1px solid #dee2e6;
    color: #111827;
}

.back-btn:hover {
    background: #f8f9fa;
    transform: translateY(-2px);
}

@media(max-width: 992px) {

    .car-image {
        min-height: 350px;
    }

    .car-content {
        padding: 35px;
    }

    .car-title {
        font-size: 2.1rem;
    }

    .info-grid {
        grid-template-columns: 1fr;
    }
}

</style>

<section class="car-hero">

    <div class="container">

        <h1 class="hero-title">

            {{ car.brand }} {{ car.model }}

        </h1>

        <p class="hero-subtitle">

            Premium car experience with comfort and performance.

        </p>

    </div>

</section>

<div class="container car-page">

    <div class="car-container">

        <div class="row g-0">

            <div class="col-lg-5">

                {% if car.image %}

                    <img
                        src="{{ asset('uploads/cars/' ~ car.image) }}"
                        class="car-image"
                        alt="{{ car.brand }}">

                {% else %}

                    <div class="d-flex justify-content-center align-items-center h-100 bg-light">

                        <h5 class="text-muted">
                            No Image Available
                        </h5>

                    </div>

                {% endif %}

            </div>

            <div class="col-lg-7">

                <div class="car-content">

                    {% if car.status == 'available' %}

                        <span class="car-badge badge-available">

                            ● Available

                        </span>

                    {% else %}

                        <span class="car-badge badge-unavailable">

                            ● Unavailable

                        </span>

                    {% endif %}

                    <h2 class="car-title">

                        {{ car.brand }} {{ car.model }}

                    </h2>

                    <p class="car-subtitle">

                        {{ car.year ?: 'Modern Vehicle' }}

                    </p>

                    <div class="info-grid">

                        <div class="info-card">

                            <span class="info-label">
                                Transmission
                            </span>

                            <div class="info-value">
                                {{ car.transmission ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="info-card">

                            <span class="info-label">
                                Fuel Type
                            </span>

                            <div class="info-value">
                                {{ car.fuelType ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="info-card">

                            <span class="info-label">
                                Seats
                            </span>

                            <div class="info-value">
                                {{ car.seats ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="info-card">

                            <span class="info-label">
                                Registration
                            </span>

                            <div class="info-value">
                                {{ car.registrationNumber }}
                            </div>

                        </div>

                    </div>

                    <div class="price-box">

                        <div class="price-label">

                            Price Per Day

                        </div>

                        <div class="price-value">

                            {{ car.pricePerDay }} €

                        </div>

                    </div>

                    <div class="description-box">

                        {{ car.description ?: 'No description available for this vehicle.' }}

                    </div>

                    <div class="action-buttons">

                        {% if car.status == 'available' %}

                            <a href="{{ path('app_reservation_new', {'car': car.id}) }}"
                               class="btn custom-btn book-btn">

                                Book Now

                            </a>

                        {% else %}

                            <button class="btn custom-btn book-btn"
                                    disabled>

                                Unavailable

                            </button>

                        {% endif %}

                        <a href="{{ path('app_car_index') }}"
                           class="btn custom-btn back-btn">

                            Back

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
