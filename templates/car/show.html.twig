{% extends 'base.html.twig' %}

{% block title %}
    {{ car.brand }} {{ car.model }}
{% endblock %}

{% block body %}

<section class="car-details-hero">

    <div class="container">

        <h1 class="car-details-hero-title">
            {{ car.brand }} {{ car.model }}
        </h1>

        <p class="car-details-hero-subtitle">
            Premium car experience with comfort and performance.
        </p>

    </div>

</section>

<div class="container car-details-page">

    <div class="car-details-container">

        <div class="row g-0">

            <div class="col-lg-5">

                {% if car.image %}

                    <img
                        src="{{ asset('uploads/cars/' ~ car.image) }}"
                        class="car-details-image"
                        alt="{{ car.brand }}">

                {% else %}

                    <div class="d-flex justify-content-center align-items-center h-100 bg-light">

                        <h5 class="text-muted">
                            No Image Available
                        </h5>

                    </div>

                {% endif %}

            </div>

            <div class="col-lg-7">

                <div class="car-details-content">

                    {% if car.status == 'available' %}

                        <span class="car-details-badge badge-available">
                            ● Available
                        </span>

                    {% else %}

                        <span class="car-details-badge badge-unavailable">
                            ● Unavailable
                        </span>

                    {% endif %}

                    <h2 class="car-details-title">
                        {{ car.brand }} {{ car.model }}
                    </h2>

                    <p class="car-details-subtitle">
                        {{ car.year ?: 'Modern Vehicle' }}
                    </p>

                    <div class="car-details-grid">

                        <div class="car-details-info-card">

                            <span class="car-details-label">
                                Transmission
                            </span>

                            <div class="car-details-value">
                                {{ car.transmission ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="car-details-info-card">

                            <span class="car-details-label">
                                Fuel Type
                            </span>

                            <div class="car-details-value">
                                {{ car.fuelType ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="car-details-info-card">

                            <span class="car-details-label">
                                Seats
                            </span>

                            <div class="car-details-value">
                                {{ car.seats ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="car-details-info-card">

                            <span class="car-details-label">
                                Registration
                            </span>

                            <div class="car-details-value">
                                {{ car.registrationNumber }}
                            </div>

                        </div>

                    </div>

                    <div class="car-details-price-box">

                        <div class="car-details-price-label">
                            Price Per Day
                        </div>

                        <div class="car-details-price-value">
                            {{ car.pricePerDay }} €
                        </div>

                    </div>

                    <div class="car-details-description">

                        {{ car.description ?: 'No description available for this vehicle.' }}

                    </div>

                    <div class="car-details-actions">

                        {% if car.status == 'available' %}

                            <a href="{{ path('app_reservation_new', {'car': car.id}) }}"
                               class="btn car-details-btn book-btn">

                                Book Now

                            </a>

                        {% else %}

                            <button class="btn car-details-btn book-btn" disabled>

                                Unavailable

                            </button>

                        {% endif %}

                        <a href="{{ path('app_car_index') }}"
                           class="btn car-details-btn back-btn">

                            Back

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
