{% extends 'base.html.twig' %}

{% block title %}
    {{ car.brand }} {{ car.model }}
{% endblock %}

{% block body %}

<style>

.car-page {
    margin-top: 120px;
    margin-bottom: 80px;
}

.car-container {
    background: #ffffff;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
}

.car-image {
    width: 100%;
    height: 100%;
    min-height: 520px;
    object-fit: cover;
}

.car-content {
    padding: 50px;
}

.car-badge {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 20px;
}

.badge-available {
    background: #d1fae5;
    color: #065f46;
}

.badge-unavailable {
    background: #fee2e2;
    color: #991b1b;
}

.car-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 10px;
}

.car-subtitle {
    color: #6b7280;
    font-size: 16px;
    margin-bottom: 35px;
}

.info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
}

.info-card {
    background: #f8f9fa;
    border-radius: 18px;
    padding: 20px;
    transition: 0.2s ease;
}

.info-card:hover {
    transform: translateY(-2px);
    background: #f1f3f5;
}

.info-label {
    display: block;
    color: #6c757d;
    font-size: 14px;
    margin-bottom: 8px;
}

.info-value {
    font-size: 18px;
    font-weight: 700;
}

.price-box {
    background: #111827;
    color: white;
    border-radius: 20px;
    padding: 25px;
    margin-bottom: 35px;
}

.price-label {
    font-size: 14px;
    opacity: 0.8;
}

.price-value {
    font-size: 2rem;
    font-weight: 800;
}

.description-box {
    background: #f8f9fa;
    border-radius: 18px;
    padding: 25px;
    line-height: 1.8;
    color: #495057;
}

.back-btn {
    border-radius: 12px;
    padding: 12px 24px;
}

</style>

<div class="container car-page">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">
                Car Details
            </h1>

            <p class="text-muted mb-0">
                Modern vehicle overview
            </p>

        </div>

        <a href="{{ path('app_car_index') }}"
           class="btn btn-outline-dark back-btn">

            ← Back

        </a>

    </div>

    <div class="car-container">

        <div class="row g-0">

            {# IMAGE #}
            <div class="col-lg-5">

                {% if car.image %}

                    <img
                        src="{{ asset('uploads/cars/' ~ car.image) }}"
                        class="car-image"
                        alt="{{ car.brand }}">

                {% else %}

                    <div class="d-flex justify-content-center align-items-center h-100 bg-light">

                        <h5 class="text-muted">
                            No Image
                        </h5>

                    </div>

                {% endif %}

            </div>

            {# CONTENT #}
            <div class="col-lg-7">

                <div class="car-content">

                    {% if car.status == 'available' %}

                        <span class="car-badge badge-available">
                            ● Available
                        </span>

                    {% else %}

                        <span class="car-badge badge-unavailable">
                            ● Unavailable
                        </span>

                    {% endif %}

                    <h2 class="car-title">
                        {{ car.brand }} {{ car.model }}
                    </h2>

                    <p class="car-subtitle">
                        {{ car.year ?: 'Modern vehicle' }}
                    </p>

                    <div class="info-grid">

                        <div class="info-card">

                            <span class="info-label">
                                Transmission
                            </span>

                            <div class="info-value">
                                {{ car.transmission ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="info-card">

                            <span class="info-label">
                                Fuel Type
                            </span>

                            <div class="info-value">
                                {{ car.fuelType ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="info-card">

                            <span class="info-label">
                                Seats
                            </span>

                            <div class="info-value">
                                {{ car.seats ?: 'N/A' }}
                            </div>

                        </div>

                        <div class="info-card">

                            <span class="info-label">
                                Registration
                            </span>

                            <div class="info-value">
                                {{ car.registrationNumber }}
                            </div>

                        </div>

                    </div>

                    <div class="price-box">

                        <div class="price-label">
                            Price Per Day
                        </div>

                        <div class="price-value">
                            {{ car.pricePerDay }} €
                        </div>

                    </div>

                    <div class="description-box">

                        {{ car.description ?: 'No description available.' }}

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
