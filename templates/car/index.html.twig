{% extends 'base.html.twig' %}

{% block title %}Cars{% endblock %}

{% block body %}

<style>

.car-card {
    border: none;
    border-radius: 22px;
    overflow: hidden;
    transition: 0.3s ease;
    background: white;
    box-shadow: 0 6px 24px rgba(0,0,0,0.07);
    height: 100%;
}

.car-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 14px 35px rgba(0,0,0,0.12);
}

.car-image {
    width: 100%;
    height: 240px;
    object-fit: cover;
}

.car-image-placeholder {
    width: 100%;
    height: 240px;
    background: #f1f3f5;
    display: flex;
    justify-content: center;
    align-items: center;
}

.placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: #6c757d;
    font-size: 15px;
    font-weight: 600;
}

.placeholder-icon {
    font-size: 3rem;
}

.car-body {
    padding: 26px;
}

.car-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 5px;
}

.car-subtitle {
    color: #6c757d;
    font-size: 14px;
}

.car-features {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
    margin-bottom: 24px;
}

.feature-badge {
    background: #f1f3f5;
    padding: 8px 14px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
}

.price-box {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.price {
    font-size: 1.7rem;
    font-weight: 800;
    color: #198754;
}

.price small {
    font-size: 14px;
    color: #6c757d;
    font-weight: 500;
}

.status-badge {
    padding: 8px 15px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
}

.available {
    background: #d1e7dd;
    color: #146c43;
}

.unavailable {
    background: #f8d7da;
    color: #842029;
}

.custom-btn {
    border-radius: 14px;
    padding: 11px 16px;
    font-weight: 600;
    transition: 0.2s ease;
}

.custom-btn:hover {
    transform: translateY(-1px);
}

.buttons-wrapper {
    display: flex;
    gap: 14px;
    margin-top: 18px;
}

.buttons-wrapper .btn {
    flex: 1;
}

.filter-box {
    background: white;
    border-radius: 22px;
    padding: 30px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.06);
    margin-bottom: 40px;
}

</style>

<section class="hero-wrap hero-wrap-2 js-fullheight"
         style="background-image: url('{{ asset('images/bg_3.jpg') }}');">

    <div class="overlay"></div>

    <div class="container">

        <div class="row no-gutters slider-text js-fullheight align-items-end">

            <div class="col-md-9 pb-5">

                <h1 class="mb-3 text-white fw-bold">
                    Choose Your Car
                </h1>

            </div>

        </div>

    </div>

</section>

<section class="ftco-section bg-light">

    <div class="container">

        {# FILTERS #}
        <div class="filter-box">

            <form method="GET">

                <div class="row g-3 align-items-end">

                    {# SEARCH #}
                    <div class="col-lg-4">

                        <label class="form-label fw-semibold">
                            Search Car
                        </label>

                        <input
                            type="text"
                            name="search"
                            class="form-control form-control-lg"
                            placeholder="BMW, Mercedes..."
                            value="{{ app.request.get('search') }}">

                    </div>

                    {# TRANSMISSION #}
                    <div class="col-lg-3">

                        <label class="form-label fw-semibold">
                            Transmission
                        </label>

                        <select
                            name="transmission"
                            class="form-select form-select-lg">

                            <option value="">
                                All
                            </option>

                            <option value="Automatic"
                                {% if app.request.get('transmission') == 'Automatic' %}
                                    selected
                                {% endif %}
                            >
                                Automatic
                            </option>

                            <option value="Manual"
                                {% if app.request.get('transmission') == 'Manual' %}
                                    selected
                                {% endif %}
                            >
                                Manual
                            </option>

                        </select>

                    </div>

                    {# FUEL TYPE #}
                    <div class="col-lg-3">

                        <label class="form-label fw-semibold">
                            Fuel Type
                        </label>

                        <select
                            name="fuelType"
                            class="form-select form-select-lg">

                            <option value="">
                                All
                            </option>

                            <option value="Petrol"
                                {% if app.request.get('fuelType') == 'Petrol' %}
                                    selected
                                {% endif %}
                            >
                                Petrol
                            </option>

                            <option value="Diesel"
                                {% if app.request.get('fuelType') == 'Diesel' %}
                                    selected
                                {% endif %}
                            >
                                Diesel
                            </option>

                            <option value="Electric"
                                {% if app.request.get('fuelType') == 'Electric' %}
                                    selected
                                {% endif %}
                            >
                                Electric
                            </option>

                        </select>

                    </div>

                    {# AVAILABLE #}
                    <div class="col-lg-2">

                        <div class="form-check mt-4">

                            <input
                                type="checkbox"
                                class="form-check-input"
                                name="available"
                                value="1"
                                id="available"
                                {% if app.request.get('available') %}
                                    checked
                                {% endif %}
                            >

                            <label
                                class="form-check-label fw-semibold"
                                for="available">

                                Available Only

                            </label>

                        </div>

                    </div>

                    {# BUTTONS #}
                    <div class="col-12 mt-3 d-flex gap-3">

                        <button class="btn btn-success px-4 py-2 rounded-3">

                            Search

                        </button>

                        <a href="{{ path('app_car_index') }}"
                           class="btn btn-outline-dark px-4 py-2 rounded-3">

                            Reset

                        </a>

                    </div>

                </div>

            </form>

        </div>

        <div class="row g-4">

            {% for car in cars %}

                <div class="col-lg-4 col-md-6">

                    <div class="car-card">

                        {# IMAGE #}
                        {% if car.image %}

                            <img
                                src="{{ asset('uploads/cars/' ~ car.image) }}"
                                class="car-image"
                                alt="{{ car.brand }}">

                        {% else %}

                            <div class="car-image-placeholder">

                                <div class="placeholder-content">

                                    <div class="placeholder-icon">
                                        🚘
                                    </div>

                                    <span>
                                        No Image Available
                                    </span>

                                </div>

                            </div>

                        {% endif %}

                        <div class="car-body">

                            {# TITLE #}
                            <h3 class="car-title">
                                {{ car.brand }} {{ car.model }}
                            </h3>

                            <div class="car-subtitle">
                                {{ car.year ?: 'Modern Vehicle' }}
                            </div>

                            {# FEATURES #}
                            <div class="car-features">

                                <span class="feature-badge">
                                    🚘 {{ car.transmission ?: 'Automatic' }}
                                </span>

                                <span class="feature-badge">
                                    ⛽ {{ car.fuelType ?: 'Petrol' }}
                                </span>

                                <span class="feature-badge">
                                    👥 {{ car.seats ?: 5 }} Seats
                                </span>

                            </div>

                            {# PRICE #}
                            <div class="price-box">

                                <div class="price">

                                    {{ car.pricePerDay }} €

                                    <small>/day</small>

                                </div>

                                {% if car.status == 'available' %}

                                    <span class="status-badge available">
                                        Available
                                    </span>

                                {% else %}

                                    <span class="status-badge unavailable">
                                        Unavailable
                                    </span>

                                {% endif %}

                            </div>

                            {# BUTTONS #}
                            <div class="buttons-wrapper">

                                <a href="{{ path('app_car_show', {'id': car.id}) }}"
                                   class="btn btn-outline-dark custom-btn">

                                    Details

                                </a>

                                {% if car.status == 'available' %}

                                    <a href="{{ path('app_reservation_new', {'car': car.id}) }}"
                                       class="btn btn-success custom-btn">

                                        Book Now

                                    </a>

                                {% else %}

                                    <button class="btn btn-secondary custom-btn" disabled>

                                        Unavailable

                                    </button>

                                {% endif %}

                            </div>

                        </div>

                    </div>

                </div>

            {% else %}

                <div class="col-12 text-center">

                    <div class="alert alert-light shadow-sm rounded-4 p-4">

                        No cars found

                    </div>

                </div>

            {% endfor %}

        </div>

    </div>

</section>

{% endblock %}
