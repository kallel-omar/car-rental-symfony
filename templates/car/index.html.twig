{% extends 'base.html.twig' %}

{% block title %}Cars{% endblock %}

{% block body %}

<section class="cars-hero-section">

    <div class="container">

        <h1 class="cars-hero-title">
            Choose Your Car
        </h1>

        <p class="cars-hero-subtitle">
            Browse premium vehicles and reserve instantly.
        </p>

    </div>

</section>

<section class="cars-wrapper">

    <div class="container">

        <div class="filter-box">

            <h3 class="filter-title">
                Search & Filters
            </h3>

            <form method="GET">

                <div class="row g-4 align-items-end">

                    <div class="col-lg-4">
                        <label class="form-label">Search Car</label>

                        <input
                            type="text"
                            name="search"
                            class="form-control"
                            placeholder="BMW, Mercedes..."
                            value="{{ app.request.get('search') }}">
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label">Transmission</label>

                        <select name="transmission" class="form-select">
                            <option value="">All</option>

                            <option value="Automatic"
                                {% if app.request.get('transmission') == 'Automatic' %}selected{% endif %}>
                                Automatic
                            </option>

                            <option value="Manual"
                                {% if app.request.get('transmission') == 'Manual' %}selected{% endif %}>
                                Manual
                            </option>
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label">Fuel Type</label>

                        <select name="fuelType" class="form-select">
                            <option value="">All</option>

                            <option value="Petrol"
                                {% if app.request.get('fuelType') == 'Petrol' %}selected{% endif %}>
                                Petrol
                            </option>

                            <option value="Diesel"
                                {% if app.request.get('fuelType') == 'Diesel' %}selected{% endif %}>
                                Diesel
                            </option>

                            <option value="Electric"
                                {% if app.request.get('fuelType') == 'Electric' %}selected{% endif %}>
                                Electric
                            </option>
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label">Seats</label>

                        <select name="seats" class="form-select">
                            <option value="">Any</option>

                            <option value="2" {% if app.request.get('seats') == '2' %}selected{% endif %}>2 Seats</option>
                            <option value="4" {% if app.request.get('seats') == '4' %}selected{% endif %}>4 Seats</option>
                            <option value="5" {% if app.request.get('seats') == '5' %}selected{% endif %}>5 Seats</option>
                            <option value="7" {% if app.request.get('seats') == '7' %}selected{% endif %}>7 Seats</option>
                        </select>
                    </div>

                    <div class="col-lg-2 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input
                                type="checkbox"
                                class="form-check-input"
                                name="available"
                                value="1"
                                id="available"
                                {% if app.request.get('available') %}checked{% endif %}>

                            <label class="form-check-label fw-semibold" for="available">
                                Available Only
                            </label>
                        </div>
                    </div>

                    <div class="col-12">

                        <div class="d-flex flex-wrap align-items-center mt-5 search-actions">

                            <button type="submit" class="search-btn">
                                Search Cars
                            </button>

                            <a href="{{ path('app_car_index') }}"
                               class="btn reset-filter-btn">
                                Reset Filters
                            </a>

                        </div>

                    </div>

                </div>

            </form>

        </div>

        <div class="row g-4">

            {% for car in cars %}

                <div class="col-lg-4 col-md-6">

                    <div class="cars-page-card">

                        {% if car.image %}

                            <img
                                src="{{ asset('uploads/cars/' ~ car.image) }}"
                                class="cars-page-image"
                                alt="{{ car.brand }}">

                        {% else %}

                            <div class="cars-page-image-placeholder">

                                <div class="placeholder-content">

                                    <div class="placeholder-icon">
                                        🚘
                                    </div>

                                    <span>
                                        No Image Available
                                    </span>

                                </div>

                            </div>

                        {% endif %}

                        <div class="cars-page-body">

                            <h3 class="cars-page-title">
                                {{ car.brand }} {{ car.model }}
                            </h3>

                            <div class="car-subtitle">
                                {{ car.year ?: 'Modern Vehicle' }}
                            </div>

                            <div class="car-features">

                                <span class="feature-badge">
                                    🚘 {{ car.transmission ?: 'Automatic' }}
                                </span>

                                <span class="feature-badge">
                                    ⛽ {{ car.fuelType ?: 'Petrol' }}
                                </span>

                                <span class="feature-badge">
                                    👥 {{ car.seats ?: 5 }} Seats
                                </span>

                            </div>

                            <div class="price-box">

                                <div class="price">
                                    {{ car.pricePerDay }} €
                                    <small>/day</small>
                                </div>

                                {% if car.status == 'available' %}

                                    <span class="status-badge available">
                                        Available
                                    </span>

                                {% else %}

                                    <span class="status-badge unavailable">
                                        Unavailable
                                    </span>

                                {% endif %}

                            </div>

                            <div class="buttons-wrapper">

                                <a href="{{ path('app_car_show', {'id': car.id}) }}"
                                   class="btn btn-outline-dark custom-btn">
                                    Details
                                </a>

                                {% if car.status == 'available' %}

                                    <a href="{{ path('app_reservation_new', {'car': car.id}) }}"
                                       class="btn btn-success custom-btn">
                                        Book Now
                                    </a>

                                {% else %}

                                    <button class="btn btn-secondary custom-btn" disabled>
                                        Unavailable
                                    </button>

                                {% endif %}

                            </div>

                        </div>

                    </div>

                </div>

            {% else %}

                <div class="col-12 text-center">

                    <div class="empty-box">

                        <div class="empty-icon">
                            🚘
                        </div>

                        <h3 class="fw-bold">
                            No Cars Found
                        </h3>

                        <p class="text-muted mb-0">
                            Try changing your search filters.
                        </p>

                    </div>

                </div>

            {% endfor %}

        </div>

    </div>

</section>

{% endblock %}
