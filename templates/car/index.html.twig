{% extends 'base.html.twig' %}

{% block title %}Cars{% endblock %}

{% block body %}

<style>

body {
    background: #f8f9fa;
}

.hero-section {
    background: linear-gradient(135deg, #111827, #1f2937);
    padding: 90px 0 140px;
    border-radius: 0 0 40px 40px;
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: "";
    position: absolute;
    width: 420px;
    height: 420px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    top: -140px;
    right: -120px;
}

.hero-title {
    color: white;
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 12px;
}

.hero-subtitle {
    color: rgba(255,255,255,0.7);
    font-size: 17px;
}

.cars-wrapper {
    margin-top: -80px;
    position: relative;
    z-index: 10;
}

.filter-box {
    background: white;
    border-radius: 28px;
    padding: 35px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
    margin-bottom: 45px;
}

.filter-title {
    font-size: 1.4rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 30px;
}

.form-label {
    font-weight: 700;
    color: #111827;
    margin-bottom: 12px;
}

.form-control,
.form-select {
    border-radius: 16px;
    padding: 14px 16px;
    border: 1px solid #e5e7eb;
    transition: 0.25s ease;
    background: #fafafa;
    height: 56px;
}

.form-control:focus,
.form-select:focus {
    border-color: #198754;
    box-shadow: 0 0 0 0.15rem rgba(25,135,84,.12);
    background: white;
}

.search-btn {
    background: linear-gradient(135deg, #198754, #157347);
    border: none;
    border-radius: 16px;
    padding: 13px 24px;
    color: white;
    font-weight: 700;
    transition: 0.25s ease;
}

.search-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(25,135,84,0.25);
}

.reset-btn {
    border-radius: 16px;
    padding: 13px 24px;
    font-weight: 700;
}

.search-btn,
.reset-btn {
    min-width: 180px;
    height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.car-card {
    border: none;
    border-radius: 28px;
    overflow: hidden;
    transition: 0.3s ease;
    background: white;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
    height: 100%;
}

.car-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 18px 45px rgba(0,0,0,0.12);
}

.car-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
}

.car-image-placeholder {
    width: 100%;
    height: 250px;
    background: #f1f3f5;
    display: flex;
    justify-content: center;
    align-items: center;
}

.placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: #6c757d;
    font-size: 15px;
    font-weight: 600;
}

.placeholder-icon {
    font-size: 3rem;
}

.car-body {
    padding: 28px;
}

.car-title {
    font-size: 1.45rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 6px;
}

.car-subtitle {
    color: #6b7280;
    font-size: 14px;
}

.car-features {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
    margin-bottom: 28px;
}

.feature-badge {
    background: #f3f4f6;
    padding: 9px 15px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
}

.price-box {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.price {
    font-size: 1.8rem;
    font-weight: 800;
    color: #198754;
}

.price small {
    font-size: 14px;
    color: #6b7280;
    font-weight: 500;
}

.status-badge {
    padding: 9px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
}

.available {
    background: #d1e7dd;
    color: #146c43;
}

.unavailable {
    background: #f8d7da;
    color: #842029;
}

.custom-btn {
    border-radius: 16px;
    padding: 12px 18px;
    font-weight: 700;
    transition: 0.25s ease;
}

.custom-btn:hover {
    transform: translateY(-2px);
}

.buttons-wrapper {
    display: flex;
    gap: 14px;
    margin-top: 18px;
}

.buttons-wrapper .btn {
    flex: 1;
}

.empty-box {
    background: white;
    border-radius: 28px;
    padding: 70px 30px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
}

.empty-icon {
    font-size: 4rem;
    margin-bottom: 20px;
}

</style>

<section class="hero-section">

    <div class="container">

        <h1 class="hero-title">

            Choose Your Car

        </h1>

        <p class="hero-subtitle">

            Browse premium vehicles and reserve instantly.

        </p>

    </div>

</section>

<section class="cars-wrapper">

    <div class="container">

        {# FILTERS #}
        <div class="filter-box">

            <h3 class="filter-title">

                Search & Filters

            </h3>

            <form method="GET">

                <div class="row g-4 align-items-end">

                    {# SEARCH #}
                    <div class="col-lg-4">

                        <label class="form-label">
                            Search Car
                        </label>

                        <input
                            type="text"
                            name="search"
                            class="form-control"
                            placeholder="BMW, Mercedes..."
                            value="{{ app.request.get('search') }}">

                    </div>

                    {# TRANSMISSION #}
                    <div class="col-lg-2">

                        <label class="form-label">
                            Transmission
                        </label>

                        <select
                            name="transmission"
                            class="form-select">

                            <option value="">
                                All
                            </option>

                            <option value="Automatic"
                                {% if app.request.get('transmission') == 'Automatic' %}
                                    selected
                                {% endif %}
                            >
                                Automatic
                            </option>

                            <option value="Manual"
                                {% if app.request.get('transmission') == 'Manual' %}
                                    selected
                                {% endif %}
                            >
                                Manual
                            </option>

                        </select>

                    </div>

                    {# FUEL TYPE #}
                    <div class="col-lg-2">

                        <label class="form-label">
                            Fuel Type
                        </label>

                        <select
                            name="fuelType"
                            class="form-select">

                            <option value="">
                                All
                            </option>

                            <option value="Petrol"
                                {% if app.request.get('fuelType') == 'Petrol' %}
                                    selected
                                {% endif %}
                            >
                                Petrol
                            </option>

                            <option value="Diesel"
                                {% if app.request.get('fuelType') == 'Diesel' %}
                                    selected
                                {% endif %}
                            >
                                Diesel
                            </option>

                            <option value="Electric"
                                {% if app.request.get('fuelType') == 'Electric' %}
                                    selected
                                {% endif %}
                            >
                                Electric
                            </option>

                        </select>

                    </div>

                    {# SEATS #}
                    <div class="col-lg-2">

                        <label class="form-label">
                            Seats
                        </label>

                        <select
                            name="seats"
                            class="form-select">

                            <option value="">
                                Any
                            </option>

                            <option value="2"
                                {% if app.request.get('seats') == '2' %}
                                    selected
                                {% endif %}
                            >
                                2 Seats
                            </option>

                            <option value="4"
                                {% if app.request.get('seats') == '4' %}
                                    selected
                                {% endif %}
                            >
                                4 Seats
                            </option>

                            <option value="5"
                                {% if app.request.get('seats') == '5' %}
                                    selected
                                {% endif %}
                            >
                                5 Seats
                            </option>

                            <option value="7"
                                {% if app.request.get('seats') == '7' %}
                                    selected
                                {% endif %}
                            >
                                7 Seats
                            </option>

                        </select>

                    </div>

                    {# AVAILABLE #}
                    <div class="col-lg-2 d-flex align-items-center">

                        <div class="form-check mt-4">

                            <input
                                type="checkbox"
                                class="form-check-input"
                                name="available"
                                value="1"
                                id="available"
                                {% if app.request.get('available') %}
                                    checked
                                {% endif %}
                            >

                            <label
                                class="form-check-label fw-semibold"
                                for="available">

                                Available Only

                            </label>

                        </div>

                    </div>

                   {# BUTTONS #}
                   <div class="col-12">

                       <div class="d-flex flex-wrap align-items-center mt-5 gap-4">

                           <button type="submit"
                                   class="search-btn">

                               Search Cars

                           </button>

                           <a href="{{ path('app_car_index') }}"
                              class="btn btn-outline-dark reset-btn">

                               Reset Filters

                           </a>

                       </div>

                   </div>


                </div>

            </form>

        </div>

        <div class="row g-4">

            {% for car in cars %}

                <div class="col-lg-4 col-md-6">

                    <div class="car-card">

                        {% if car.image %}

                            <img
                                src="{{ asset('uploads/cars/' ~ car.image) }}"
                                class="car-image"
                                alt="{{ car.brand }}">

                        {% else %}

                            <div class="car-image-placeholder">

                                <div class="placeholder-content">

                                    <div class="placeholder-icon">
                                        🚘
                                    </div>

                                    <span>
                                        No Image Available
                                    </span>

                                </div>

                            </div>

                        {% endif %}

                        <div class="car-body">

                            <h3 class="car-title">

                                {{ car.brand }} {{ car.model }}

                            </h3>

                            <div class="car-subtitle">

                                {{ car.year ?: 'Modern Vehicle' }}

                            </div>

                            <div class="car-features">

                                <span class="feature-badge">
                                    🚘 {{ car.transmission ?: 'Automatic' }}
                                </span>

                                <span class="feature-badge">
                                    ⛽ {{ car.fuelType ?: 'Petrol' }}
                                </span>

                                <span class="feature-badge">
                                    👥 {{ car.seats ?: 5 }} Seats
                                </span>

                            </div>

                            <div class="price-box">

                                <div class="price">

                                    {{ car.pricePerDay }} €

                                    <small>/day</small>

                                </div>

                                {% if car.status == 'available' %}

                                    <span class="status-badge available">

                                        Available

                                    </span>

                                {% else %}

                                    <span class="status-badge unavailable">

                                        Unavailable

                                    </span>

                                {% endif %}

                            </div>

                            <div class="buttons-wrapper">

                                <a href="{{ path('app_car_show', {'id': car.id}) }}"
                                   class="btn btn-outline-dark custom-btn">

                                    Details

                                </a>

                                {% if car.status == 'available' %}

                                    <a href="{{ path('app_reservation_new', {'car': car.id}) }}"
                                       class="btn btn-success custom-btn">

                                        Book Now

                                    </a>

                                {% else %}

                                    <button class="btn btn-secondary custom-btn" disabled>

                                        Unavailable

                                    </button>

                                {% endif %}

                            </div>

                        </div>

                    </div>

                </div>

            {% else %}

                <div class="col-12 text-center">

                    <div class="empty-box">

                        <div class="empty-icon">

                            🚘

                        </div>

                        <h3 class="fw-bold">

                            No Cars Found

                        </h3>

                        <p class="text-muted mb-0">

                            Try changing your search filters.

                        </p>

                    </div>

                </div>

            {% endfor %}

        </div>

    </div>

</section>

{% endblock %}
