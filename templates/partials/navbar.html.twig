<style>

.lux-navbar {
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(14px);
    padding: 18px 0;
    transition: 0.3s ease;
    border-bottom: 1px solid rgba(0,0,0,0.05);
}

.lux-logo {
    font-size: 1.9rem;
    font-weight: 800;
    color: #111 !important;
    text-decoration: none;
    letter-spacing: -1px;
}

.lux-logo span {
    color: #198754;
}

.lux-nav {
    gap: 10px;
}

.lux-link {
    color: #495057 !important;
    font-weight: 600;
    padding: 10px 18px !important;
    border-radius: 12px;
    transition: 0.25s ease;
    position: relative;
}

.lux-link:hover {
    background: #f1f3f5;
    color: #111 !important;
}

.lux-btn {
    background: #198754;
    color: white !important;
    padding: 11px 22px !important;
    border-radius: 14px;
    font-weight: 700;
    margin-left: 14px;
    box-shadow: 0 8px 20px rgba(25,135,84,0.25);
    transition: 0.25s ease;
}

.lux-btn:hover {
    background: #157347;
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(25,135,84,0.35);
}

.navbar-toggler {
    border: none !important;
    box-shadow: none !important;
}

body {
    padding-top: 100px;
}

@media (max-width: 991px) {

    .lux-navbar {
        padding: 15px 0;
    }

    .lux-link {
        margin-top: 8px;
    }

    .lux-btn {
        display: inline-block;
        margin-top: 14px;
        margin-left: 0;
    }
}

</style>

<nav class="navbar navbar-expand-lg lux-navbar fixed-top">

    <div class="container">

        <a class="navbar-brand lux-logo"
           href="{{ path('home') }}">

            Car<span>Book</span>

        </a>

        <button class="navbar-toggler"
                type="button"
                data-toggle="collapse"
                data-target="#navbarNav">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse"
             id="navbarNav">

            <ul class="navbar-nav ml-auto align-items-lg-center lux-nav">

                <li class="nav-item">

                    <a href="{{ path('app_car_index') }}"
                       class="nav-link lux-link">

                        Cars

                    </a>

                </li>

                {% if app.user %}

                    <li class="nav-item">

                        <a href="{{ path('app_my_reservations') }}"
                           class="nav-link lux-link">

                            My Reservations

                        </a>

                    </li>

                    {% if is_granted('ROLE_ADMIN') %}

                        <li class="nav-item">

                            <a href="{{ path('app_reservation_index') }}"
                               class="nav-link lux-link">

                                Dashboard

                            </a>

                        </li>

                    {% endif %}

                    <li class="nav-item">

                        <a href="{{ path('app_logout') }}"
                           class="nav-link lux-btn">

                            Logout

                        </a>

                    </li>

                {% else %}

                    <li class="nav-item">

                        <a href="{{ path('app_login') }}"
                           class="nav-link lux-link">

                            Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a href="{{ path('app_register') }}"
                           class="nav-link lux-btn">

                            Register

                        </a>

                    </li>

                {% endif %}

            </ul>

        </div>

    </div>

</nav>
