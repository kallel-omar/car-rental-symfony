<style>

.lux-navbar {
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(14px);
    padding: 18px 0;
    transition: 0.3s ease;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    z-index: 9999;
}

.lux-logo {
    font-size: 1.9rem;
    font-weight: 800;
    color: #111 !important;
    text-decoration: none;
    letter-spacing: -1px;
}

.lux-logo span {
    color: #198754;
}

.lux-nav {
    gap: 10px;
}

.lux-link {
    color: #495057 !important;
    font-weight: 600;
    padding: 10px 18px !important;
    border-radius: 12px;
    transition: 0.25s ease;
    position: relative;
}

.lux-link:hover {
    background: #f1f3f5;
    color: #111 !important;
}

.lux-btn {
    background: #198754;
    color: white !important;
    padding: 11px 22px !important;
    border-radius: 14px;
    font-weight: 700;
    margin-left: 14px;
    box-shadow: 0 8px 20px rgba(25,135,84,0.25);
    transition: 0.25s ease;
}

.lux-btn:hover {
    background: #157347;
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(25,135,84,0.35);
}

.profile-dropdown {
    position: relative;

}

.profile-btn {
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 14px;
    padding: 10px 18px;
    font-weight: 600;
    color: #111 !important;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: 0.25s ease;
    cursor: pointer;
    text-decoration: none !important;
}

.profile-btn:hover {
    background: #f1f3f5;
    color: #111 !important;
}

.profile-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #198754;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
}

.profile-menu {
    position: absolute;
    top: calc(100% - 2px);
    right: 0;
    width: 260px;
    background: white;
    border-radius: 20px;
    box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    padding: 14px;
    display: none;
    z-index: 999;
}

.profile-dropdown:hover .profile-menu {
    display: block;
}

.profile-header {
    padding: 14px;
    border-bottom: 1px solid #f1f3f5;
    margin-bottom: 10px;
}

.profile-name {
    font-weight: 700;
    color: #111827;
}

.profile-email {
    font-size: 14px;
    color: #6b7280;
}

.profile-item {
    display: block;
    padding: 12px 14px;
    border-radius: 14px;
    text-decoration: none !important;
    color: #111827;
    font-weight: 600;
    transition: 0.2s ease;
}

.profile-item:hover {
    background: #f8f9fa;
    color: #198754;
}

.profile-logout {
    background: #198754;
    color: white !important;
    text-align: center;
    margin-top: 10px;
}

.profile-logout:hover {
    background: #157347 !important;
    color: white !important;
}

.navbar-toggler {
    border: none !important;
    box-shadow: none !important;
}



@media (max-width: 991px) {

    .lux-navbar {
        padding: 15px 0;
    }

    .lux-link {
        margin-top: 8px;
    }

    .lux-btn {
        display: inline-block;
        margin-top: 14px;
        margin-left: 0;
    }

    .profile-menu {
        position: static;
        width: 100%;
        margin-top: 15px;
    }
.lux-navbar {
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(14px);
    padding: 18px 0;
    transition: transform 0.35s ease, background 0.3s ease;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    z-index: 9999;
}
}

</style>

<nav class="navbar navbar-expand-lg lux-navbar fixed-top">

    <div class="container">

        <a class="navbar-brand lux-logo"
           href="{{ path('home') }}">

            Car<span>Book</span>

        </a>

        <button class="navbar-toggler"
                type="button"
                data-toggle="collapse"
                data-target="#navbarNav">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse"
             id="navbarNav">

            <ul class="navbar-nav ml-auto align-items-lg-center lux-nav">

                <li class="nav-item">

                    <a href="{{ path('app_car_index') }}"
                       class="nav-link lux-link">

                        Cars

                    </a>

                </li>

                {% if app.user %}

                    <li class="nav-item">

                        <a href="{{ path('app_my_reservations') }}"
                           class="nav-link lux-link">

                            My Reservations

                        </a>

                    </li>

                    {% if is_granted('ROLE_ADMIN') %}

                        <li class="nav-item">

                            <a href="{{ path('admin_dashboard') }}"
                               class="nav-link lux-link">

                                Dashboard

                            </a>

                        </li>

                    {% endif %}

                    {# PROFILE DROPDOWN #}
                    <li class="nav-item profile-dropdown">

                        <div class="profile-btn">

                            <div class="profile-avatar">

                                {{ app.user.email|first|upper }}

                            </div>

                            <span>

                                Account

                            </span>

                        </div>

                        <div class="profile-menu">

                            <div class="profile-header">

                            <div class="profile-name d-flex align-items-center">

                                   <span class="mr-3">

                                       {{ app.user.fullName ?: 'Customer Account' }}

                                   </span>

                                   {% if 'ROLE_SUPERVISER' in app.user.roles %}

                                       <span class="badge badge-warning px-2 py-1">

                                           Superviser

                                       </span>

                                   {% elseif 'ROLE_ADMIN' in app.user.roles %}

                                       <span class="badge badge-dark px-2 py-1">

                                           Admin

                                       </span>

                                   {% else %}

                                       <span class="badge badge-success px-2 py-1">

                                           User

                                       </span>

                                   {% endif %}

                               </div>

                                <div class="profile-email">

                                    {{ app.user.email }}

                                </div>

                            </div>

                            <a href="{{ path('app_user_profile') }}"
                               class="profile-item">

                                👤 My Profile

                            </a>

                            <a href="{{ path('app_my_reservations') }}"
                               class="profile-item">

                                📅 My Reservations

                            </a>

                            {% if is_granted('ROLE_ADMIN') %}

                                <a href="{{ path('admin_dashboard') }}"
                                   class="profile-item">

                                    ⚙️ Admin Dashboard

                                </a>

                            {% endif %}

                            <a href="{{ path('app_logout') }}"
                               class="profile-item profile-logout">

                                Logout

                            </a>

                        </div>

                    </li>

                {% else %}

                    <li class="nav-item">

                        <a href="{{ path('app_login') }}"
                           class="nav-link lux-link">

                            Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a href="{{ path('app_register') }}"
                           class="nav-link lux-btn">

                            Register

                        </a>

                    </li>

                {% endif %}

            </ul>

        </div>

    </div>

</nav>
