{% extends 'base.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block body %}


<section class="reset-request-section">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-5">

                <div class="reset-request-card">

                    {% for flash_error in app.flashes('reset_password_error') %}

                        <div class="alert alert-danger">

                            {{ flash_error }}

                        </div>

                    {% endfor %}

                    <h1 class="reset-request-title">

                        Forgot Password

                    </h1>

                    <p class="reset-request-subtitle">

                        Enter your email to receive a password reset link.

                    </p>

                    {{ form_start(requestForm) }}

                    <div class="mb-4">

                        {{ form_label(requestForm.email) }}

                        {{ form_widget(
                            requestForm.email,
                            {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Enter your email'
                                }
                            }
                        ) }}

                        <div class="error-box">

                            {{ form_errors(requestForm.email) }}

                        </div>

                    </div>

                    <div class="reset-request-info-box">

                        We will send you a secure link to reset your password.

                    </div>

                    <button class="reset-request-btn">

                        Send Reset Email

                    </button>

                    {{ form_end(requestForm) }}

                </div>

            </div>

        </div>

    </div>

</section>

{% endblock %}
