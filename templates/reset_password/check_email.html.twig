{% extends 'base.html.twig' %}

{% block title %}Password Reset Email Sent{% endblock %}

{% block body %}

<style>

.check-email-section {
    min-height: 100vh;
    background: #f8f9fa;
    padding: 80px 0;
}

.check-email-card {
    background: white;
    border: none;
    border-radius: 28px;
    padding: 50px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
    text-align: center;
}

.success-icon {
    width: 90px;
    height: 90px;
    margin: 0 auto 25px;
    border-radius: 24px;
    background: linear-gradient(135deg, #198754, #157347);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    color: white;
}

.check-email-title {
    font-size: 2rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 15px;
}

.check-email-text {
    color: #6b7280;
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 18px;
}

.retry-link {
    display: inline-block;
    margin-top: 20px;
    color: #198754;
    font-weight: 700;
    text-decoration: none;
    transition: 0.2s ease;
}

.retry-link:hover {
    text-decoration: underline;
}

.expire-box {
    background: #f1f3f5;
    border-radius: 16px;
    padding: 16px;
    margin-top: 25px;
    font-size: 14px;
    color: #495057;
}

</style>

<section class="check-email-section">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-6">

                <div class="check-email-card">

                    <div class="success-icon">

                        ✉️

                    </div>

                    <h1 class="check-email-title">

                        Email Sent Successfully

                    </h1>

                    <p class="check-email-text">

                        If an account matching your email exists,
                        a password reset link has been sent.

                    </p>

                    <div class="expire-box">

                        This reset link will expire in

                        <strong>

                            {{ resetToken.expirationMessageKey|trans(
                                resetToken.expirationMessageData,
                                'ResetPasswordBundle'
                            ) }}

                        </strong>

                    </div>

                    <p class="check-email-text mt-4">

                        If you don't receive the email,
                        please check your spam folder.

                    </p>

                    <a href="{{ path('app_forgot_password_request') }}"
                       class="retry-link">

                        Try Again

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

{% endblock %}
