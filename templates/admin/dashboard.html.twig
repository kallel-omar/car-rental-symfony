{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

<h1 class="mb-4">Dashboard</h1>

<div class="row">

    <div class="col-md-4">
        <div class="card bg-primary text-white shadow border-0 mb-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Cars</h5>
                    <h2>{{ carsCount }}</h2>
                </div>

                <i class="fa-solid fa-car fa-3x"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-success text-white shadow border-0 mb-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Reservations</h5>
                    <h2>{{ reservationsCount }}</h2>
                </div>

                <i class="fa-solid fa-calendar-check fa-3x"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-dark text-white shadow border-0 mb-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Revenue</h5>
                    <h2>{{ totalRevenue }} €</h2>
                </div>

                <i class="fa-solid fa-sack-dollar fa-3x"></i>
            </div>
        </div>
    </div>

</div>

<hr>

<h3>Latest Reservations</h3>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>User</th>
            <th>Car</th>
            <th>Price</th>
        </tr>
    </thead>

    <tbody>
    {% for r in reservations %}
        <tr>
            <td>{{ r.id }}</td>
            <td>{{ r.user.email }}</td>
            <td>{{ r.car.model }}</td>
            <td>{{ r.totalPrice }} €</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% endblock %}
