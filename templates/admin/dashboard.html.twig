{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

<style>

.custom-table th,
.custom-table td {
    padding: 18px 22px !important;
    vertical-align: middle;
}

.custom-table thead th {
    white-space: nowrap;
}

.custom-table tbody tr:hover {
    background-color: #f8f9fa;
    transition: 0.2s;
}

.dashboard-card {
    border: none;
    border-radius: 18px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.06);
    transition: 0.3s;
}

.dashboard-card:hover {
    transform: translateY(-4px);
}

.stat-icon {
    width: 65px;
    height: 65px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: white;
}

.bg-cars {
    background: #0d6efd;
}

.bg-reservations {
    background: #198754;
}

.bg-revenue {
    background: #111827;
}

.stat-number {
    font-size: 2rem;
    font-weight: 800;
}

.quick-btn {
    border-radius: 50px;
    padding: 12px 24px;
    font-weight: 600;
}

.chart-container {
    height: 350px;
}

</style>

<div class="container py-5">

    {# HEADER #}
    <div class="mb-5">

        <h1 class="fw-bold mb-1">
            Dashboard
        </h1>

        <p class="text-muted mb-0">
            Manage your platform analytics and activity
        </p>

    </div>

    {# STATS #}
    <div class="row g-4 mb-4">

        <div class="col-lg-4">

            <div class="card dashboard-card">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <div class="text-muted fw-semibold mb-2">
                                Total Cars
                            </div>

                            <div class="stat-number">
                                {{ carsCount }}
                            </div>

                        </div>

                        <div class="stat-icon bg-cars">
                            🚘
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="card dashboard-card">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <div class="text-muted fw-semibold mb-2">
                                Reservations
                            </div>

                            <div class="stat-number">
                                {{ reservationsCount }}
                            </div>

                        </div>

                        <div class="stat-icon bg-reservations">
                            📅
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="card dashboard-card">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <div class="text-muted fw-semibold mb-2">
                                Revenue
                            </div>

                            <div class="stat-number">
                                {{ totalRevenue }} €
                            </div>

                        </div>

                        <div class="stat-icon bg-revenue">
                            💰
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    {# LATEST RESERVATIONS #}
    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body p-4">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h4 class="fw-bold mb-1">
                        Latest Reservations
                    </h4>

                    <p class="text-muted mb-0">
                        Recent customer reservations
                    </p>

                </div>

            </div>

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0 custom-table">

                    <thead class="table-dark">

                        <tr>

                            <th>Client</th>
                            <th>Client Phone</th>
                            <th>Car</th>
                            <th>Period</th>
                            <th>Status</th>
                            <th>Total</th>

                        </tr>

                    </thead>

                    <tbody>

                    {% for r in reservations %}

                        <tr
                            onclick="window.location='{{ path('app_reservation_show', {'id': r.id}) }}'"
                            style="cursor:pointer;"
                        >

                            <td>

                                {{ r.user.fullName ?: 'No Name' }}

                            </td>

                            <td>

                                {{ r.user.phoneNumber ?: 'No Phone' }}

                            </td>

                            <td>

                                <div class="fw-semibold">

                                    {{ r.car.brand }}
                                    {{ r.car.model }}

                                </div>

                            </td>

                            <td>

                                <div>

                                    <strong>From:</strong>

                                    {{ r.startDate
                                        ? r.startDate|date('d M Y')
                                        : ''
                                    }}

                                </div>

                                <div>

                                    <strong>To:</strong>

                                    {{ r.endDate
                                        ? r.endDate|date('d M Y')
                                        : ''
                                    }}

                                </div>

                            </td>

                            <td>

                                {% if r.status == 'pending' %}

                                    <span class="badge bg-warning text-dark">

                                        Pending

                                    </span>

                                {% elseif r.status == 'approved' %}

                                    <span class="badge bg-success">

                                        Approved

                                    </span>

                                {% elseif r.status == 'completed' %}

                                    <span class="badge bg-primary">

                                        Completed

                                    </span>

                                {% else %}

                                    <span class="badge bg-danger">

                                        Rejected

                                    </span>

                                {% endif %}

                            </td>

                            <td class="fw-bold text-success">

                                {{ r.totalPrice }} €

                            </td>

                        </tr>

                    {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

{% endblock %}
