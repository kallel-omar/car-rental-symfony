
{% extends 'admin/layout.html.twig' %}

{% block title %}Cars{% endblock %}

{% block body %}

<style>

.custom-table th,
.custom-table td {
    padding: 20px 25px !important;
    vertical-align: middle;
}

.custom-table thead th {
    white-space: nowrap;
}

.custom-table tbody tr:hover {
    background-color: #f8f9fa;
    transition: 0.2s;
}

.car-image {
    width: 90px;
    height: 70px;
    object-fit: cover;
    border-radius: 12px;
}

.status-badge {
    padding: 8px 15px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
}

.available {
    background: #d1e7dd;
    color: #146c43;
}

.unavailable {
    background: #f8d7da;
    color: #842029;
}

</style>

<div class="container py-5">

    {# HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">
                Cars
            </h1>

            <p class="text-muted mb-0">
                Manage all cars
            </p>

        </div>

        <a
            href="{{ path('app_car_new') }}"
            class="btn btn-success shadow-sm px-4 rounded-pill">

            + Add Car

        </a>

    </div>

    {# FILTER BUTTONS #}
    <div class="d-flex gap-2 flex-wrap mb-4">

        <a
            href="{{ path('admin_cars') }}"
            class="btn btn-dark rounded-pill px-4">

            All

        </a>

        <a
            <a href="{{ path('admin_cars', {'status': 'available'}) }}"
            class="btn btn-success rounded-pill px-4">

            Available

        </a>

        <a
            href="{{ path('admin_cars', {'status': 'unavailable'}) }}"
            class="btn btn-danger rounded-pill px-4">

            Unavailable

        </a>

    </div>

    {# TABLE CARD #}
    <div class="card border-0 shadow-sm">

        <div class="card-body p-4">

            <div class="table-responsive p-2">

                <table class="table table-hover align-middle mb-0 custom-table">

                    <thead class="table-dark">

                        <tr>


                            <th>Image</th>
                            <th>Car</th>

                            <th>Price</th>
                            <th>Status</th>
                            <th class="text-center">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                    {% for car in cars %}

                        <tr>



                            {# IMAGE #}
                            <td>

                                {% if car.image %}

                                    <img
                                        src="{{ asset('uploads/cars/' ~ car.image) }}"
                                        class="car-image"
                                        alt="{{ car.brand }}">

                                {% else %}

                                    <div class="text-muted">
                                        No Image
                                    </div>

                                {% endif %}

                            </td>

                            {# CAR #}
                            <td>

                                <div class="fw-semibold">
                                    {{ car.brand }} {{ car.model }}
                                </div>

                                <small class="text-muted">
                                    {{ car.year ?: 'Modern Vehicle' }}
                                </small>

                            </td>



                            {# PRICE #}
                            <td class="fw-bold text-success">
                                {{ car.pricePerDay }} €
                            </td>

                            {# STATUS #}
                            <td>

                                {% if car.status == 'available' %}

                                    <span class="status-badge available">

                                        Available

                                    </span>

                                {% else %}

                                    <span class="status-badge unavailable">

                                        Unavailable

                                    </span>

                                {% endif %}

                            </td>

                            {# ACTIONS #}
                            <td class="text-center">

                                <div class="d-flex gap-2 justify-content-center">

                                    <a
                                        href="{{ path('app_car_show', {'id': car.id}) }}"
                                        class="btn btn-sm btn-primary rounded-pill px-3">

                                        View

                                    </a>

                                    <a
                                        href="{{ path('app_car_edit', {'id': car.id}) }}"
                                        class="btn btn-sm btn-warning rounded-pill px-3">

                                        Edit

                                    </a>

                                    <form
                                        method="post"
                                        action="{{ path('app_car_delete', {'id': car.id}) }}"
                                        onsubmit="return confirm('Are you sure you want to delete this car?');"
                                    >

                                        <input
                                            type="hidden"
                                            name="_token"
                                            value="{{ csrf_token('delete' ~ car.id) }}">

                                        <button
                                            class="btn btn-sm btn-danger rounded-pill px-3">

                                            Delete

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>

                    {% else %}

                        <tr>

                            <td colspan="9"
                                class="text-center py-5 text-muted">

                                <h5>
                                    No cars found
                                </h5>

                            </td>

                        </tr>

                    {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

{% endblock %}
