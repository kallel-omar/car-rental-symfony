{% extends 'admin/layout.html.twig' %}

{% block title %}Cars{% endblock %}

{% block body %}

<div class="container py-5">

     {# HEADER #}
        <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-2">
                Cars
            </h1>

            <p class="text-muted mb-2">
                Manage all cars
            </p>
        <a
                    href="{{ path('app_car_new') }}"
                    class="btn btn-primary shadow-sm px-4 ">

                    + Add Car

                </a>

        </div>
    <form method="get" class="d-flex gap-2 mb-4">

        {% if currentStatus %}
            <input
                type="hidden"
                name="status"
                value="{{ currentStatus }}">
        {% endif %}

        <input
            type="text"
            name="search"
            value="{{ search }}"
            class="form-control rounded-pill px-4"
            placeholder="Search by brand, model or year">

        <button class="btn btn-dark rounded-pill px-4">

            Search

        </button>

    </form>



    </div>




    <div class="card border-0 shadow-sm">

         <div class="d-flex gap-2 flex-wrap mb-4 p-4 pb-0">

                <a
                    href="{{ path('admin_cars') }}"
                    class="btn btn-dark rounded-pill px-4">

                    All

                </a>

                <a
                    href="{{ path('admin_cars', {'status': 'rented'}) }}"
                    class="btn rounded-pill px-4"
                    style="background:#0ea5e9;color:white;">

                    Rented

                </a>
            <a
                href="{{ path('admin_cars', {'status': 'booked'}) }}"
                class="btn rounded-pill px-4"
                style="background:#f59e0b;color:white;">

                Booked

            </a>

                <a
                    href="{{ path('admin_cars', {'status': 'available'}) }}"
                    class="btn btn-success rounded-pill px-4">

                    Available

                </a>

                <a
                    href="{{ path('admin_cars', {'status': 'unavailable'}) }}"
                    class="btn btn-danger rounded-pill px-4">

                    Unavailable

                </a>

            </div>

        <div class="card-body p-4">

            <div class="table-responsive p-2">

                <table class="table table-hover align-middle mb-0 custom-table">

                    <thead class="table-dark">

                        <tr>

                            <th>Image</th>
                            <th>Car</th>
                            <th>Price</th>
                            <th>Car Status</th>
                            <th>Rental Status</th>
                            <th class="text-center">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                    {% for car in cars %}

                        <tr>

                            <td>

                                {% if car.image %}

                                    <img
                                        src="{{ asset('uploads/cars/' ~ car.image) }}"
                                        class="car-image"
                                        alt="{{ car.brand }}">

                                {% else %}

                                    <div class="text-muted">
                                        No Image
                                    </div>

                                {% endif %}

                            </td>

                            <td>

                                <div class="fw-semibold">
                                    {{ car.brand }} {{ car.model }}
                                </div>

                                <small class="text-muted">
                                    {{ car.year ?: 'Modern Vehicle' }}
                                </small>

                            </td>

                            <td class="fw-bold text-success">
                                {{ car.pricePerDay }} €
                            </td>

                            <td>

                                {% if car.status == 'available' %}

                                    <span class="status-badge available">

                                        Available

                                    </span>

                                {% else %}

                                    <span class="status-badge unavailable">

                                        Unavailable

                                    </span>

                                {% endif %}

                            </td>
                        <td>

                            {% set rentalStatus = 'garage' %}
                            {% set activeProcess = null %}

                            {% for process in car.rentalProcesses %}

                                {% if process.status == 'waiting_pickup' %}

                                    {% set rentalStatus = 'ready' %}
                                    {% set activeProcess = process %}

                                {% elseif process.status == 'picked_up' %}

                                    {% set rentalStatus = 'rented' %}
                                    {% set activeProcess = process %}

                                {% endif %}

                            {% endfor %}

                            {% if rentalStatus == 'ready' %}

                                <span
                                    class="status-badge"
                                    style="background:#fef3c7;color:#92400e;">

                                    Ready To Pickup

                                </span>

                                <div class="small text-dark mt-2">

                                    {{ activeProcess.reservation.startDate|date('d M Y') }}

                                    {% if activeProcess.pickupTime %}

                                        • {{ activeProcess.pickupTime|date('H:i') }}

                                    {% endif %}

                                </div>

                            {% elseif rentalStatus == 'rented' %}

                                <span
                                    class="status-badge"
                                    style="background:#fee2e2;color:#991b1b;">

                                    Rented

                                </span>

                                <div class="small text-danger mt-2">

                                    Return:
                                    {{ activeProcess.reservation.endDate|date('d M Y') }}
                                     {% if activeProcess.pickupTime %}

                                       / {{ activeProcess.pickupTime|date('H:i') }}
                                        {% endif %}


                                </div>

                            {% else %}

                                <span
                                    class="status-badge"
                                    style="background:#dbeafe;color:#1d4ed8;">

                                    In Garage

                                </span>

                            {% endif %}

                        </td>

                            <td class="text-center">

                                <div class="d-flex gap-2 justify-content-center">

                                    <a
                                        href="{{ path('app_car_show', {'id': car.id}) }}"
                                        class="btn btn-sm btn-primary rounded-pill px-3">

                                        View

                                    </a>

                                    <a
                                        href="{{ path('app_car_edit', {'id': car.id}) }}"
                                        class="btn btn-sm btn-warning rounded-pill px-3">

                                        Edit

                                    </a>

                                    <form
                                        method="post"
                                        action="{{ path('app_car_delete', {'id': car.id}) }}"
                                        onsubmit="return confirm('Are you sure you want to delete this car?');">

                                        <input
                                            type="hidden"
                                            name="_token"
                                            value="{{ csrf_token('delete' ~ car.id) }}">

                                        <button
                                            class="btn btn-sm btn-danger rounded-pill px-3">

                                            Delete

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>

                    {% else %}

                        <tr>

                            <td
                                colspan="5"
                                class="text-center py-5 text-muted">

                                <h5>
                                    No cars found
                                </h5>

                            </td>

                        </tr>

                    {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

{% endblock %}
