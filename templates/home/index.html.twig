{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}

<style>

.hero-modern {
    min-height: 92vh;
    background:
        linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
        url('{{ asset("images/bg_1.jpg") }}');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    border-radius: 0 0 40px 40px;
}

.hero-content {
    max-width: 700px;
}

.hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(10px);
    color: white;
    padding: 10px 18px;
    border-radius: 50px;
    margin-bottom: 24px;
    font-weight: 600;
    font-size: 14px;
}

.hero-title {
    font-size: 4rem;
    font-weight: 800;
    color: white;
    line-height: 1.15;
    margin-bottom: 24px;
}

.hero-text {
    color: rgba(255,255,255,0.85);
    font-size: 18px;
    line-height: 1.8;
    margin-bottom: 35px;
}

.hero-buttons {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
}

.hero-btn-primary {
    background: #198754;
    color: white;
    padding: 15px 28px;
    border-radius: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: 0.25s ease;
    box-shadow: 0 10px 24px rgba(25,135,84,0.3);
}

.hero-btn-primary:hover {
    background: #157347;
    color: white;
    transform: translateY(-2px);
}

.hero-btn-secondary {
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(10px);
    color: white;
    padding: 15px 28px;
    border-radius: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: 0.25s ease;
}

.hero-btn-secondary:hover {
    background: rgba(255,255,255,0.2);
    color: white;
}

.section-modern {
    padding: 100px 0;
}

.section-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: #111;
}

.section-subtitle {
    color: #6c757d;
    max-width: 700px;
    margin: auto;
    line-height: 1.8;
}

.feature-card {
    background: white;
    padding: 40px 30px;
    border-radius: 24px;
    text-align: center;
    box-shadow: 0 6px 24px rgba(0,0,0,0.05);
    transition: 0.3s ease;
    height: 100%;
}

.feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 14px 35px rgba(0,0,0,0.08);
}

.feature-icon {
    width: 80px;
    height: 80px;
    margin: auto auto 24px;
    border-radius: 22px;
    background: #198754;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 2rem;
}

.feature-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 14px;
}

.feature-text {
    color: #6c757d;
    line-height: 1.8;
}

.cta-section {
    background: linear-gradient(135deg, #198754, #157347);
    padding: 90px 40px;
    border-radius: 40px;
    text-align: center;
    color: white;
}

.cta-title {
    font-size: 2.7rem;
    font-weight: 800;
    margin-bottom: 20px;
}

.cta-text {
    max-width: 700px;
    margin: auto;
    line-height: 1.8;
    margin-bottom: 35px;
    color: rgba(255,255,255,0.9);
}

.cta-btn {
    background: white;
    color: #198754;
    padding: 15px 30px;
    border-radius: 16px;
    text-decoration: none;
    font-weight: 700;
    transition: 0.25s ease;
    display: inline-block;
}

.cta-btn:hover {
    transform: translateY(-2px);
    color: #157347;
}

@media(max-width: 991px) {

    .hero-title {
        font-size: 2.8rem;
    }

    .section-title {
        font-size: 2rem;
    }

    .cta-title {
        font-size: 2rem;
    }
}

</style>

{# HERO #}
<section class="hero-modern">

    <div class="container">

        <div class="hero-content">

            <div class="hero-badge">

                Premium Car Rental Experience

            </div>

            <h1 class="hero-title">

                Find The Perfect Car For Your Journey

            </h1>

            <p class="hero-text">

                Discover modern, comfortable and affordable vehicles
                with a seamless booking experience designed for your needs.

            </p>

            <div class="hero-buttons">

                <a href="{{ path('app_car_index') }}"
                   class="hero-btn-primary">

                    Explore Cars

                </a>

                {% if not app.user %}

                    <a href="{{ path('app_register') }}"
                       class="hero-btn-secondary">

                        Get Started

                    </a>

                {% endif %}

            </div>

        </div>

    </div>

</section>

{# FEATURES #}
<section class="section-modern bg-light">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="section-title">

                Why Choose CarBook

            </h2>

            <p class="section-subtitle">

                We provide a modern rental experience with premium vehicles,
                affordable prices and fast reservations.

            </p>

        </div>

        <div class="row g-4">

            <div class="col-lg-4">

                <div class="feature-card">

                    <div class="feature-icon">
                        🚘
                    </div>

                    <h4 class="feature-title">

                        Premium Vehicles

                    </h4>

                    <p class="feature-text">

                        Choose from a wide selection of modern and comfortable vehicles.

                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="feature-card">

                    <div class="feature-icon">
                        ⚡
                    </div>

                    <h4 class="feature-title">

                        Fast Booking

                    </h4>

                    <p class="feature-text">

                        Reserve your car in minutes with our simple booking process.

                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="feature-card">

                    <div class="feature-icon">
                        💰
                    </div>

                    <h4 class="feature-title">

                        Affordable Prices

                    </h4>

                    <p class="feature-text">

                        Enjoy competitive pricing with no hidden fees.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>
{# FEATURED CARS #}
<section class="section-modern bg-light">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="section-title">

                Featured Vehicles

            </h2>

            <p class="section-subtitle">

                Explore our latest premium vehicles available for reservation.

            </p>

        </div>

        <div class="row g-4">

            {% for car in cars %}

                <div class="col-lg-4 col-md-6">

                    <div class="feature-card text-start p-0 overflow-hidden">

                        {# IMAGE #}
                        {% if car.image %}

                            <img
                                src="{{ asset('uploads/cars/' ~ car.image) }}"
                                style="
                                    width:100%;
                                    height:240px;
                                    object-fit:cover;
                                "
                                alt="{{ car.brand }}">

                        {% else %}

                            <div class="d-flex align-items-center justify-content-center bg-light"
                                 style="height:240px;">

                                <div class="text-center text-muted">

                                    <div style="font-size:3rem;">
                                        🚘
                                    </div>

                                    No Image Available

                                </div>

                            </div>

                        {% endif %}

                        <div class="p-4">

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <h4 class="mb-0 fw-bold">

                                    {{ car.brand }} {{ car.model }}

                                </h4>

                                {% if car.status == 'available' %}

                                    <span class="badge bg-success">
                                        Available
                                    </span>

                                {% else %}

                                    <span class="badge bg-danger">
                                        Unavailable
                                    </span>

                                {% endif %}

                            </div>

                            <div class="d-flex flex-wrap gap-2 mb-4">

                                <span class="badge bg-light text-dark p-2">

                                    🚘 {{ car.transmission ?: 'Auto' }}

                                </span>

                                <span class="badge bg-light text-dark p-2">

                                    ⛽ {{ car.fuelType ?: 'Petrol' }}

                                </span>

                                <span class="badge bg-light text-dark p-2">

                                    👥 {{ car.seats ?: 5 }} Seats

                                </span>

                            </div>

                            <div class="d-flex justify-content-between align-items-center">

                                <div>

                                    <div class="fw-bold text-success"
                                         style="font-size:1.5rem;">

                                        {{ car.pricePerDay }} €

                                    </div>

                                    <small class="text-muted">
                                        per day
                                    </small>

                                </div>

                                <a href="{{ path('app_car_show', {'id': car.id}) }}"
                                   class="hero-btn-primary"
                                   style="
                                       padding:12px 18px;
                                       font-size:14px;
                                   ">

                                    View Details

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

        <div class="text-center mt-5">

            <a href="{{ path('app_car_index') }}"
               class="hero-btn-primary">

                View All Cars

            </a>

        </div>

    </div>

</section>

{# CTA #}
<section class="section-modern">

    <div class="container">

        <div class="cta-section">

            <h2 class="cta-title">

                Ready To Drive?

            </h2>

            <p class="cta-text">

                Browse our collection of premium vehicles
                and book your perfect ride today.

            </p>

            <a href="{{ path('app_car_index') }}"
               class="cta-btn">

                Browse Cars

            </a>

        </div>

    </div>

</section>

{% endblock %}
