{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}

<section class="hero-modern">

    <div class="container">

        <div class="hero-content">

            <div class="hero-badge">
                Premium Car Rental Experience
            </div>

            <h1 class="home-hero-title">
                Find The Perfect Car For Your Journey
            </h1>

            <p class="home-hero-text">
                Discover premium vehicles with a modern booking experience.
            </p>

            <div class="hero-buttons">

                <a href="{{ path('app_car_index') }}"
                   class="hero-btn-primary">
                    Explore Cars
                </a>

                {% if not app.user %}
                    <a href="{{ path('app_register') }}"
                       class="hero-btn-secondary">
                        Get Started
                    </a>
                {% endif %}

            </div>

        </div>

    </div>

</section>

<section class="section-modern bg-light">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="section-title">
                Why Choose CarBook
            </h2>

            <p class="section-subtitle">
                Premium vehicles, fast booking and affordable prices.
            </p>

        </div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">🚘</div>
                    <h4 class="feature-title">Premium Vehicles</h4>
                    <p class="feature-text">
                        Modern and comfortable cars for every journey.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <h4 class="feature-title">Fast Booking</h4>
                    <p class="feature-text">
                        Reserve your vehicle in just a few clicks.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">💰</div>
                    <h4 class="feature-title">Affordable Prices</h4>
                    <p class="feature-text">
                        Competitive daily prices with no hidden fees.
                    </p>
                </div>
            </div>

        </div>

    </div>

</section>

<section class="section-modern bg-light">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="section-title">
                Featured Vehicles
            </h2>

            <p class="section-subtitle">
                Explore our latest premium vehicles available for reservation.
            </p>

        </div>

        <div class="row g-4">

            {% for car in cars %}

                <div class="col-lg-4 col-md-6">

                    <div class="home-car-card">

                        {% if car.image %}

                            <img
                                src="{{ asset('uploads/cars/' ~ car.image) }}"
                                class="home-car-image"
                                alt="{{ car.brand }}">

                        {% else %}

                            <div class="car-image-placeholder">
                                <div class="text-center text-muted">
                                    <div style="font-size:3rem;">🚘</div>
                                    No Image Available
                                </div>
                            </div>

                        {% endif %}

                        <div class="car-body">

                            <h3 class="home-car-title">
                                {{ car.brand }} {{ car.model }}
                            </h3>

                            <div class="car-features">

                                <span class="feature-badge">
                                    🚘 {{ car.transmission ?: 'Auto' }}
                                </span>

                                <span class="feature-badge">
                                    ⛽ {{ car.fuelType ?: 'Petrol' }}
                                </span>

                                <span class="feature-badge">
                                    👥 {{ car.seats ?: 5 }} Seats
                                </span>

                            </div>

                            <div class="price-box">

                                <div class="price">
                                    {{ car.pricePerDay }} €
                                    <small>/day</small>
                                </div>

                                {% if car.status == 'available' %}
                                    <span class="status-badge available">
                                        Available
                                    </span>
                                {% else %}
                                    <span class="status-badge unavailable">
                                        Unavailable
                                    </span>
                                {% endif %}

                            </div>

                            <div class="car-buttons">

                                <a href="{{ path('app_car_show', {'id': car.id}) }}"
                                   class="btn btn-outline-dark">
                                    Details
                                </a>

                                {% if car.status == 'available' %}

                                    <a href="{{ path('app_reservation_new', {'car': car.id}) }}"
                                       class="btn btn-success">
                                        Book Now
                                    </a>

                                {% else %}

                                    <button class="btn btn-secondary" disabled>
                                        Unavailable
                                    </button>

                                {% endif %}

                            </div>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

        <div class="text-center mt-5">

            <a href="{{ path('app_car_index') }}"
               class="hero-btn-primary">
                View All Cars
            </a>

        </div>

    </div>

</section>

<section class="section-modern">

    <div class="container">

        <div class="cta-section">

            <h2 class="cta-title">
                Ready To Drive?
            </h2>

            <p class="cta-text">
                Browse our collection and reserve your perfect vehicle today.
            </p>

            <a href="{{ path('app_car_index') }}"
               class="cta-btn">
                Browse Cars
            </a>

        </div>

    </div>

</section>

{% endblock %}
