{% extends 'admin/layout.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">Users Management</h1>
            <p class="text-muted mb-0">Manage all registered users</p>*


        </div>
    <form method="get" class="d-flex gap-2 mb-4">

        {% if currentType %}
            <input type="hidden" name="type" value="{{ currentType }}">
        {% endif %}

        <input
            type="text"
            name="search"
            value="{{ search }}"
            class="form-control rounded-pill px-4"
            placeholder="Search by name, email or phone">

        <button class="btn btn-dark rounded-pill px-4">
            Search
        </button>

    </form>

    </div>

   <div class="card border-0 shadow-sm">

           <div class="d-flex gap-2 flex-wrap mb-4 p-4 pb-0">

                    <a
                        href="{{ path('app_user_index') }}"
                        class="btn btn-dark rounded-pill px-4">

                        All

                    </a>



                    <a
                        href="{{ path('app_user_index', {'type': 'clients'}) }}"
                        class="btn btn-success rounded-pill px-4">

                        Clients

                    </a>

                    <a
                        href="{{ path('app_user_index', {'type': 'staff'}) }}"
                        class="btn btn-warning rounded-pill px-4">

                        Staff

                    </a>

                </div>



        <div class="card-body p-4">

            {% if users|length > 0 %}

                <div class="table-responsive p-2">

                    <table class="table table-hover align-middle mb-0 custom-table">

                        <thead class="table-dark">

                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                        {% for user in users %}

                            <tr>

                                <td>
                                    <a href="{{ path('app_admin_user_profile', {'id': user.id}) }}"
                                       class="fw-semibold text-dark text-decoration-none">

                                        {{ user.fullName ?: 'Customer Account' }}

                                    </a>
                                </td>

                                <td>
                                    <div class="fw-semibold text-dark">
                                        {{ user.email }}
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-semibold text-dark">
                                        {{ user.phoneNumber ?: 'No Phone' }}
                                    </div>
                                </td>

                                <td>

                                    {% if 'ROLE_SUPERVISER' in user.roles %}

                                        <span class="role-badge role-superviser">
                                            Superviser
                                        </span>

                                    {% elseif 'ROLE_ADMIN' in user.roles %}

                                        <span class="role-badge role-admin">
                                            Admin
                                        </span>

                                    {% else %}

                                        <span class="role-badge role-user">
                                            User
                                        </span>

                                    {% endif %}

                                </td>

                                <td>

                                    {% if user.isVerified %}

                                        <span class="status-badge approved">
                                            Verified
                                        </span>

                                    {% else %}

                                        <span class="status-badge rejected">
                                            Not Verified
                                        </span>

                                    {% endif %}

                                </td>

                                <td class="text-center">

                                    {% if is_granted('ROLE_SUPERVISER') %}

                                        <div class="d-flex justify-content-center gap-2 flex-wrap">

                                            {% if 'ROLE_SUPERVISER' in user.roles %}

                                                {% if app.user.id != user.id %}

                                                    <form method="post"
                                                          action="{{ path('app_user_remove_superviser', {'id': user.id}) }}">

                                                        <button class="btn-action-remove">
                                                            Remove Superviser
                                                        </button>

                                                    </form>

                                                {% else %}

                                                    <button class="btn-action-disabled" disabled>
                                                        Your Account
                                                    </button>

                                                {% endif %}

                                            {% elseif 'ROLE_ADMIN' in user.roles %}

                                                <form method="post"
                                                      action="{{ path('app_user_remove_admin', {'id': user.id}) }}">

                                                    <button class="btn-action-remove">
                                                        Remove Admin
                                                    </button>

                                                </form>

                                                <form method="post"
                                                      action="{{ path('app_user_make_superviser', {'id': user.id}) }}">

                                                    <button class="btn-action-superviser">
                                                        Make Superviser
                                                    </button>

                                                </form>

                                            {% elseif user.isVerified %}

                                                <form method="post"
                                                      action="{{ path('app_user_make_admin', {'id': user.id}) }}">

                                                    <button class="btn-action-admin">
                                                        Make Admin
                                                    </button>

                                                </form>

                                                <form method="post"
                                                      action="{{ path('app_user_make_superviser', {'id': user.id}) }}">

                                                    <button class="btn-action-superviser">
                                                        Make Superviser
                                                    </button>

                                                </form>

                                            {% else %}

                                                <button class="btn-action-disabled" disabled>
                                                    User Not Verified
                                                </button>

                                            {% endif %}

                                        </div>

                                    {% else %}

                                        <span class="text-muted small">
                                            No Permission
                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                        {% endfor %}

                        </tbody>

                    </table>

                </div>
            </div>

            {% else %}

                <div class="text-center py-5">

                    <h4 class="fw-bold">No Users Found</h4>

                    <p class="text-muted mb-0">
                        There are no registered users yet.
                    </p>

                </div>

            {% endif %}

        </div>

    </div>

</div>

{% endblock %}
