{% extends 'admin/layout.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}

<style>

.users-card {
    border-radius: 24px;
    border: none;
    overflow: hidden;
}

.users-table th {
    font-size: 14px;
    font-weight: 700;
    color: #6b7280;
    border-bottom: 1px solid #f1f3f5;
    padding: 18px;
}

.users-table td {
    vertical-align: middle;
    padding: 18px;
}

.role-badge {
    padding: 10px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
}

.role-user {
    background: #dcfce7;
    color: #166534;
}

.role-admin {
    background: #111827;
    color: white;
}

.role-superviser {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
}

.status-badge {
    padding: 10px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
}

.status-verified {
    background: #dcfce7;
    color: #166534;
}

.status-not-verified {
    background: #fee2e2;
    color: #991b1b;
}

.btn-action-admin {
    background: linear-gradient(135deg, #111827, #1f2937);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 12px;
    font-weight: 600;
    transition: 0.25s ease;
}

.btn-action-admin:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(17,24,39,0.25);
    color: white;
}

.btn-action-superviser {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 12px;
    font-weight: 600;
    transition: 0.25s ease;
}

.btn-action-superviser:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(245,158,11,0.25);
    color: white;
}

.btn-action-remove {
    background: white;
    color: #dc2626;
    border: 1px solid #fecaca;
    padding: 10px 18px;
    border-radius: 12px;
    font-weight: 600;
    transition: 0.25s ease;
}

.btn-action-remove:hover {
    background: #dc2626;
    color: white;
}

.btn-action-disabled {
    background: #f3f4f6;
    color: #6b7280;
    border: none;
    padding: 10px 18px;
    border-radius: 12px;
    font-weight: 600;
}

</style>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold mb-1">

                Users Management

            </h2>

            <p class="text-muted mb-0">

                Manage all registered users

            </p>

        </div>

    </div>

    <div class="card users-card shadow-sm">

        <div class="card-body p-0">

            {% if users|length > 0 %}

                <div class="table-responsive">

                    <table class="table users-table align-middle mb-0">

                        <thead>

                            <tr>


                                 <th>Name</th>
                                  <th>Email</th>
                                 <th>Phone</th>

                                <th>Role</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>

                            </tr>

                        </thead>

                        <tbody>

                        {% for user in users %}

                            <tr>


                         <td>

                             <a href="{{ path('app_admin_user_profile', {'id': user.id}) }}"
                                class="fw-semibold text-dark text-decoration-none">

                                 {% if user.fullName %}

                                     {{ user.fullName }}

                                 {% else %}

                                     Customer Account

                                 {% endif %}

                             </a>

                         </td>

                         </td>
                          <td>

                                                             <div class="fw-semibold text-dark">

                                                                 {{ user.email }}

                                                             </div>

                                                         </td>
                             <td>

                                    <div class="fw-semibold text-dark">

                                           {{ user.phoneNumber }}

                                    </div>

                              </td>

                                <td>

                                    {% if 'ROLE_SUPERVISER' in user.roles %}

                                        <span class="role-badge role-superviser">

                                            Superviser

                                        </span>

                                    {% elseif 'ROLE_ADMIN' in user.roles %}

                                        <span class="role-badge role-admin">

                                            Admin

                                        </span>

                                    {% else %}

                                        <span class="role-badge role-user">

                                            User

                                        </span>

                                    {% endif %}

                                </td>

                                <td>

                                    {% if user.isVerified %}

                                        <span class="status-badge status-verified">

                                            Verified

                                        </span>

                                    {% else %}

                                        <span class="status-badge status-not-verified">

                                            Not Verified

                                        </span>

                                    {% endif %}

                                </td>

                                <td class="text-end">

                                    {% if is_granted('ROLE_SUPERVISER') %}

                                        <div class="d-flex justify-content-end gap-2 flex-wrap">

                                            {% if 'ROLE_SUPERVISER' in user.roles %}

                                                {% if app.user.id != user.id %}

                                                    <form method="post"
                                                          action="{{ path('app_user_remove_superviser', {'id': user.id}) }}">

                                                        <button class="btn-action-remove">

                                                            Remove Superviser

                                                        </button>

                                                    </form>

                                                {% else %}

                                                    <button class="btn-action-disabled"
                                                            disabled>

                                                        Your Account

                                                    </button>

                                                {% endif %}

                                            {% elseif 'ROLE_ADMIN' in user.roles %}

                                                <form method="post"
                                                      action="{{ path('app_user_remove_admin', {'id': user.id}) }}">

                                                    <button class="btn-action-remove">

                                                        Remove Admin

                                                    </button>

                                                </form>

                                                <form method="post"
                                                      action="{{ path('app_user_make_superviser', {'id': user.id}) }}">

                                                    <button class="btn-action-superviser">

                                                        Make Superviser

                                                    </button>

                                                </form>

                                            {% elseif user.isVerified %}

                                                <form method="post"
                                                      action="{{ path('app_user_make_admin', {'id': user.id}) }}">

                                                    <button class="btn-action-admin">

                                                        Make Admin

                                                    </button>

                                                </form>

                                                <form method="post"
                                                      action="{{ path('app_user_make_superviser', {'id': user.id}) }}">

                                                    <button class="btn-action-superviser">

                                                        Make Superviser

                                                    </button>

                                                </form>

                                            {% else %}

                                                <button class="btn-action-disabled"
                                                        disabled>

                                                    User Not Verified

                                                </button>

                                            {% endif %}

                                        </div>

                                    {% else %}

                                        <span class="text-muted small">

                                            No Permission

                                        </span>

                                    {% endif %}

                                </td>

                            </tr>

                        {% endfor %}

                        </tbody>

                    </table>

                </div>

            {% else %}

                <div class="text-center py-5">

                    <h4 class="fw-bold">

                        No Users Found

                    </h4>

                    <p class="text-muted mb-0">

                        There are no registered users yet.

                    </p>

                </div>

            {% endif %}

        </div>

    </div>

</div>

{% endblock %}
