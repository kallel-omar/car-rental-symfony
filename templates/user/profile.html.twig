{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}

<section class="profile-hero">

    <div class="container">
        <h1 class="profile-title">My Profile</h1>
        <p class="profile-subtitle">Manage your personal information and reservations</p>
    </div>

</section>

<section class="profile-wrapper">

    <div class="container">

        <div class="profile-card">

            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4">

                <div class="d-flex align-items-center ">



                    <div>

                   <div class="d-flex align-items-center flex-wrap profile-header-items">
                        <div class="profile-avatar mb-4 me-4">
                            {{ userData.email|first|upper }}
                        </div>
                        <span class="profile-name me-5">
                            {{ userData.fullName ?: 'Customer Account' }}
                        </span>

                        {% if 'ROLE_SUPERVISER' in userData.roles %}

                            <span class="badge bg-warning text-dark me-5 px-3 py-2">
                                Superviser
                            </span>

                        {% elseif 'ROLE_ADMIN' in userData.roles %}

                            <span class="badge bg-dark me-5 px-3 py-2">
                                Admin
                            </span>

                        {% else %}

                            <span class="badge bg-success text-dark me-5 px-3 py-2">
                                User
                            </span>

                        {% endif %}

                        <span class="ms-4">

                            <a href="{{ path('app_user_edit_profile') }}"
                               class="edit-profile-btn">

                                Edit Profile

                            </a>

                        </span>

                    </div>

                        <div class="profile-email mb-2">
                            {{ userData.email }}
                        </div>
                    </div>

                </div>

                <a href="{{ path('app_my_reservations') }}"
                   class="profile-stats-card text-decoration-none text-white mt-4 mt-lg-0">

                    <div class="stats-number">
                        {{ userData.reservations|length }}
                    </div>

                    <div class="stats-label">
                        Reservations →
                    </div>

                </a>

            </div>

            <div class="row">

                <div class="col-lg-4 mb-4">
                    <div class="profile-info-box">
                        <div class="profile-info-label">Phone Number</div>
                        <div class="profile-info-value">
                            {{ userData.phoneNumber ?: 'Not provided' }}
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 mb-4">
                    <div class="profile-info-box">
                        <div class="profile-info-label">Driver License Date</div>
                        <div class="profile-info-value">
                            {{ userData.licenseIssueDate
                                ? userData.licenseIssueDate|date('d M Y')
                                : 'Not provided'
                            }}
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 mb-4">
                    <div class="profile-info-box">
                        <div class="profile-info-label">Account Verification</div>
                        <div class="profile-info-value">
                            {% if userData.isVerified %}
                                <span class="text-success">✅ Verified</span>
                            {% else %}
                                <span class="text-danger">❌ Not Verified</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

            </div>

            <div class="row mt-3">

                <div class="col-lg-6 mb-4">
                    <div class="profile-document-box">

                        <div class="profile-document-title">
                            CIN Document
                        </div>

                        {% if userData.cinImage %}
                            <img
                                src="{{ asset('uploads/cin/' ~ userData.cinImage) }}"
                                class="profile-document-image">
                        {% else %}
                            <div class="alert alert-secondary rounded-4 mb-0">
                                No CIN uploaded
                            </div>
                        {% endif %}

                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="profile-document-box">

                        <div class="profile-document-title">
                            Driver License
                        </div>

                        {% if userData.licenseImage %}
                            <img
                                src="{{ asset('uploads/licenses/' ~ userData.licenseImage) }}"
                                class="profile-document-image">
                        {% else %}
                            <div class="alert alert-secondary rounded-4 mb-0">
                                No license uploaded
                            </div>
                        {% endif %}

                    </div>
                </div>

            </div>

            {% if latestReservation %}

                <div class="mt-5">

                    <h4 class="profile-section-title mb-4">
                        Current Reservation
                    </h4>

                    <div class="profile-reservation-card">

                        <div class="d-flex align-items-center">

                            {% if latestReservation.car.image %}
                                <img
                                    src="{{ asset('uploads/cars/' ~ latestReservation.car.image) }}"
                                    class="profile-reservation-image">
                            {% endif %}

                            <div class="ms-4 flex-grow-1">

                                <div class="d-flex justify-content-between flex-wrap">

                                    <div>
                                        <h5 class="fw-bold mb-1">
                                            {{ latestReservation.car.brand }}
                                            {{ latestReservation.car.model }}
                                        </h5>

                                        <div class="text-muted small">
                                            {{ latestReservation.startDate|date('d M Y') }}
                                            —
                                            {{ latestReservation.endDate|date('d M Y') }}
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <div class="fw-bold text-success">
                                            {{ latestReservation.totalPrice }} €
                                        </div>

                                        <span class="badge bg-success text-dark px-3 py-2 mt-1">
                                            Paid
                                        </span>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            {% endif %}

            {% if pendingPaymentReservation %}

                <div class="mt-4">

                    <h4 class="profile-section-title mb-4">
                        Awaiting Payment
                    </h4>

                    <div class="profile-reservation-card border-warning">

                        <div class="d-flex align-items-center">

                            {% if pendingPaymentReservation.car.image %}
                                <img
                                    src="{{ asset('uploads/cars/' ~ pendingPaymentReservation.car.image) }}"
                                    class="profile-reservation-image">
                            {% endif %}

                            <div class="ms-4 flex-grow-1">

                                <div class="d-flex justify-content-between flex-wrap">

                                    <div>
                                        <h5 class="fw-bold mb-1">
                                            {{ pendingPaymentReservation.car.brand }}
                                            {{ pendingPaymentReservation.car.model }}
                                        </h5>

                                        <div class="text-muted small">
                                            {{ pendingPaymentReservation.startDate|date('d M Y') }}
                                            —
                                            {{ pendingPaymentReservation.endDate|date('d M Y') }}
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <div class="fw-bold text-warning">
                                            {{ pendingPaymentReservation.totalPrice }} €
                                        </div>

                                        <span class="badge bg-warning text-dark px-3 py-2 mt-1">
                                            Unpaid
                                        </span>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            {% endif %}

        </div>

    </div>

</section>

{% endblock %}
