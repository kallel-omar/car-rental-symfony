{% extends 'base.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block body %}

<section class="edit-wrapper">

    <div class="container">

        <div class="edit-card">

            <div class="mb-5">

                <h1 class="edit-title">
                    Edit Profile
                </h1>

                <p class="edit-subtitle">
                    Update your personal information and documents
                </p>

            </div>

            {{ form_start(form, {
                'attr': {
                    'enctype': 'multipart/form-data'
                }
            }) }}

            <div class="edit-section-title">

                Personal Information

            </div>

            <div class="row">

                <div class="col-lg-6 mb-4">

                    {{ form_label(form.email) }}

                    {{ form_widget(form.email, {
                        'attr': {
                            'class': 'form-control'
                        }
                    }) }}

                </div>

                <div class="col-lg-6 mb-4">

                    {{ form_label(form.fullName) }}

                    {{ form_widget(form.fullName, {
                        'attr': {
                            'class': 'form-control'
                        }
                    }) }}

                </div>

                <div class="col-lg-6 mb-4">

                    {{ form_label(form.phoneNumber) }}

                    {{ form_widget(form.phoneNumber, {
                        'attr': {
                            'class': 'form-control'
                        }
                    }) }}

                </div>

                <div class="col-lg-6 mb-4">

                    {{ form_label(form.licenseIssueDate) }}

                    {{ form_widget(form.licenseIssueDate, {
                        'attr': {
                            'class': 'form-control'
                        }
                    }) }}

                </div>

            </div>

            <div class="edit-section-title mt-3">

                Documents

            </div>

            <div class="row">

                <div class="col-lg-6 mb-4">

                    <div class="edit-document-box">

                        <h5 class="mb-3 fw-bold">
                            CIN Document
                        </h5>

                        {% if app.user.cinImage %}

                            <img
                                src="{{ asset('uploads/cin/' ~ app.user.cinImage) }}"
                                class="edit-document-image mb-3"
                            >

                        {% endif %}

                        <small class="text-muted d-block mb-3">

                            Upload another image only if you want to replace it.

                        </small>

                        {{ form_widget(form.cinImage, {
                            'attr': {
                                'class': 'form-control'
                            }
                        }) }}

                    </div>

                </div>

                <div class="col-lg-6 mb-4">

                    <div class="edit-document-box">

                        <h5 class="mb-3 fw-bold">
                            Driver License
                        </h5>

                        {% if app.user.licenseImage %}

                            <img
                                src="{{ asset('uploads/licenses/' ~ app.user.licenseImage) }}"
                                class="edit-document-image mb-3"
                            >

                        {% endif %}

                        <small class="text-muted d-block mb-3">

                            Upload another image only if you want to replace it.

                        </small>

                        {{ form_widget(form.licenseImage, {
                            'attr': {
                                'class': 'form-control'
                            }
                        }) }}

                    </div>

                </div>

            </div>

            <div class="mt-4 d-flex flex-wrap align-items-center gap-3">

                <button class="save-btn">

                    Save

                </button>

                <a href="{{ path('app_user_profile') }}"
                   class="cancel-btn btn btn-dark">

                    Cancel

                </a>

            </div>

            {{ form_end(form) }}

        </div>

    </div>

</section>

{% endblock %}
