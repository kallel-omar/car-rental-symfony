{{ form_start(form) }}

<style>

.pickup-form-card{
    background:white;
    border-radius:20px;
    padding:35px;
    box-shadow:0 4px 20px rgba(0,0,0,0.05);
}

.form-section-title{
    font-size:1.3rem;
    font-weight:800;
    color:#111827;
}

.form-label{
    font-weight:700;
    color:#374151;
    margin-bottom:8px;
}

.form-control,
.form-select{
    border-radius:14px;
    padding:12px 16px;
    border:1px solid #d1d5db;
    box-shadow:none !important;
}

.form-control:focus,
.form-select:focus{
    border-color:#198754;
}

.submit-btn{
    background:#198754;
    border:none;
    border-radius:50px;
    padding:12px 28px;
    font-weight:700;
    color:white;
    transition:0.25s ease;
}

.submit-btn:hover{
    background:#157347;
}

</style>

<div class="pickup-form-card">

    <h3 class="form-section-title mb-4">

        Vehicle Pickup Preparation

    </h3>

    <div class="row">

        <div class="col-lg-6 mb-4">

            {{ form_label(form.pickupType) }}

            {{ form_widget(form.pickupType, {
                attr: {
                    class: 'form-select'
                }
            }) }}

        </div>

        <div class="col-lg-6 mb-4">

            {{ form_label(form.pickupTime) }}

            {{ form_widget(form.pickupTime, {
                attr: {
                    class: 'form-control'
                }
            }) }}

        </div>

        <div class="col-lg-6 mb-4">

            {{ form_label(form.pickupFuelLevel) }}

            {{ form_widget(form.pickupFuelLevel, {
                attr: {
                    class: 'form-select'
                }
            }) }}

        </div>

        <div class="col-lg-6 mb-4">

            {{ form_label(form.pickupKilometers) }}

            {{ form_widget(form.pickupKilometers, {
                attr: {
                    class: 'form-control',
                    placeholder: 'Example: 45210'
                }
            }) }}

        </div>

        <div class="col-12 mb-4">

            {{ form_label(form.deliveryAddress) }}

            {{ form_widget(form.deliveryAddress, {
                attr: {
                    class: 'form-control',
                    placeholder: 'Delivery address if customer requested delivery'
                }
            }) }}

        </div>

    </div>

    <div class="d-flex justify-content-end">

        <button class="submit-btn">

            {{ button_label|default('Confirm Pickup') }}

        </button>

    </div>

</div>

{{ form_end(form) }}
