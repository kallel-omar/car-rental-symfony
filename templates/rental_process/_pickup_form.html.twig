{{ form_start(form) }}



<div class="modern-form">

    <h2 class="section-title">

        Vehicle Pickup Preparation

    </h2>

    <div class="row">

        <div class="col-lg-6">

            <div class="form-group-modern">

                {{ form_label(form.pickupType) }}

                {{ form_widget(form.pickupType, {
                    attr: {
                        class: 'form-select'
                    }
                }) }}

            </div>

        </div>

        <div class="col-lg-6">

            <div class="form-group-modern">

                {{ form_label(form.pickupTime) }}

                {{ form_widget(form.pickupTime, {
                    attr: {
                        class: 'form-control'
                    }
                }) }}

            </div>

        </div>

        <div class="col-lg-6">

            <div class="form-group-modern">

                {{ form_label(form.pickupFuelLevel) }}

                {{ form_widget(form.pickupFuelLevel, {
                    attr: {
                        class: 'form-select'
                    }
                }) }}

            </div>

        </div>

        <div class="col-lg-6">

            <div class="form-group-modern">

                {{ form_label(form.pickupKilometers) }}

                {{ form_widget(form.pickupKilometers, {
                    attr: {
                        class: 'form-control',
                        placeholder: 'Example: 45210'
                    }
                }) }}

            </div>

        </div>

        <div class="col-12">

            <div class="form-group-modern">

                {{ form_label(form.deliveryAddress) }}

                {{ form_widget(form.deliveryAddress, {
                    attr: {
                        class: 'form-control',
                        placeholder: 'Delivery address if needed'
                    }
                }) }}

            </div>

        </div>

    </div>

    <div class="d-flex justify-content-end mt-4">

        <button class="pickup-btn">

            Confirm Pickup

        </button>

    </div>

</div>
{{ form_row(form._token) }}
{{ form_end(form, {'render_rest': false}) }}
