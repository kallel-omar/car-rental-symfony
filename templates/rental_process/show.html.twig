{% extends 'admin/layout.html.twig' %}

{% block title %}Rental Process{% endblock %}

{% block body %}



<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="process-title mb-1">

            Rental Process

        </h2>

        <p class="text-muted mb-0">

            Vehicle delivery and return workflow

        </p>

    </div>

    <a href="{{ path('app_rental_process_index') }}"
       class="btn btn-dark rounded-pill px-4">

        Back

    </a>

</div>

<div class="process-card">

    <div class="row">

        <div class="col-lg-5 mb-4">

            {% if rental_process.car.image %}

                <img
                    src="{{ asset('uploads/cars/' ~ rental_process.car.image) }}"
                    class="car-image"
                >

            {% endif %}

        </div>

        <div class="col-lg-7">

            <div class="row">

                <div class="col-md-6 mb-4">

                    <div class="info-card">

                        <div class="info-label">

                            Customer

                        </div>

                        <div class="info-value">

                            {{ rental_process.user.fullName }}

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="info-card">

                        <div class="info-label">

                            Vehicle

                        </div>

                        <div class="info-value">

                            {{ rental_process.car.brand }}
                            {{ rental_process.car.model }}

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="info-card">

                        <div class="info-label">

                            Pickup Type

                        </div>

                        <div class="info-value">

                            {{ rental_process.pickupType ?: 'Not selected' }}

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="info-card">

                        <div class="info-label">

                            Pickup Time

                        </div>

                        <div class="info-value">

                            {{ rental_process.pickupTime
                                ? rental_process.pickupTime|date('H:i')
                                : 'Not selected'
                            }}

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="info-card">

                        <div class="info-label">

                            Pickup Fuel

                        </div>

                        <div class="info-value">

                            {{ rental_process.pickupFuelLevel ?: 'Not added' }}

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="info-card">

                        <div class="info-label">

                            Pickup Kilometers

                        </div>

                        <div class="info-value">

                            {{ rental_process.pickupKilometers ?: '0' }} km

                        </div>

                    </div>

                </div>

                {% if rental_process.returnFuelLevel %}

                    <div class="col-md-6 mb-4">

                        <div class="info-card">

                            <div class="info-label">

                                Return Fuel

                            </div>

                            <div class="info-value">

                                {{ rental_process.returnFuelLevel }}

                            </div>

                        </div>

                    </div>

                {% endif %}

                {% if rental_process.returnKilometers %}

                    <div class="col-md-6 mb-4">

                        <div class="info-card">

                            <div class="info-label">

                                Return Kilometers

                            </div>

                            <div class="info-value">

                                {{ rental_process.returnKilometers }} km

                            </div>

                        </div>

                    </div>

                {% endif %}

                {% if rental_process.deliveryAddress %}

                    <div class="col-12 mb-4">

                        <div class="info-card">

                            <div class="info-label">

                                Delivery Address

                            </div>

                            <div class="info-value">

                                {{ rental_process.deliveryAddress }}

                            </div>

                        </div>

                    </div>

                {% endif %}

                <div class="col-12">

                    <div class="d-flex align-items-center justify-content-between flex-wrap">

                        <div>

                            <div class="info-label mb-2">

                                Current Status

                            </div>

                            {% if rental_process.status == 'waiting_pickup' %}

                                <span class="status-badge waiting">

                                    Waiting Pickup

                                </span>

                            {% elseif rental_process.status == 'picked_up' %}

                                <span class="status-badge picked">

                                    Picked Up

                                </span>

                            {% elseif rental_process.status == 'completed' %}

                                <span class="status-badge completed">

                                    Completed

                                </span>

                            {% endif %}

                        </div>

                        <div class="mt-3 mt-lg-0">

                            {% if rental_process.status == 'waiting_pickup' %}

                                <a href="{{ path(
                                    'app_rental_process_edit',
                                    {id: rental_process.id}
                                ) }}"
                                   class="btn btn-primary action-btn">

                                    Prepare Pickup

                                </a>

                            {% elseif rental_process.status == 'picked_up' %}

                                <a href="{{ path(
                                    'app_rental_process_return_edit',
                                    {id: rental_process.id}
                                ) }}"
                                   class="btn btn-success action-btn">

                                    Prepare Return

                                </a>

                            {% endif %}

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
