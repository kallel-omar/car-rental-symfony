# Environment Configuration Example

#

# Copy this file to .env.local or .env and update the values for your local machine.

#

# Do not commit real production secrets.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_with_a_random_secret
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:password@127.0.0.1:3306/car_rental?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> stripe/stripe-php ###
STRIPE_SECRET_KEY=sk_test_your_secret_key
###< stripe/stripe-php ###
