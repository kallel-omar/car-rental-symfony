# Environment Configuration

# This is an example .env file for the Car Rental Management System.
# Copy this file to .env and update the values with your configuration.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMe!WithARandomSecretKeyOfAtLeast32Characters
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Database Configuration
# Format: driver://username:password@host:port/database_name
DATABASE_URL="mysql://root:root@localhost:3306/car_rental"

# For SQLite (local development)
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"

# For PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/car_rental"
###< doctrine/doctrine-bundle ###

###> symfony/mailer-bundle ###
# Email Configuration
# MAILER_DSN=smtp://username:password@smtp.example.com:587
MAILER_DSN=smtp://localhost:25
###< symfony/mailer-bundle ###

###> Application Settings ###
# Application name and URL
APP_NAME=CarRental
APP_URL=http://localhost:8000

# Default currency
DEFAULT_CURRENCY=EUR

# Default timezone
DEFAULT_TIMEZONE=Europe/Paris
###< Application Settings ###

###> Database Settings ###
# Database name
DB_NAME=car_rental

# Database user
DB_USER=root

# Database password
DB_PASSWORD=root

# Database host
DB_HOST=localhost

# Database port
DB_PORT=3306
###< Database Settings ###

###> JWT Configuration (if using JWT auth) ###
# JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
# JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# JWT_PASSPHRASE=your_jwt_passphrase_here
###< JWT Configuration ###

###> CORS Configuration ###
# CORS_ALLOW_ORIGIN=http://localhost:3000
###< CORS Configuration ###

###> Redis Configuration (if using caching) ###
# REDIS_URL=redis://localhost:6379
###< Redis Configuration ###

###> AWS S3 Configuration (for file uploads) ###
# AWS_KEY=your_aws_key_here
# AWS_SECRET=your_aws_secret_here
# AWS_BUCKET=your_bucket_name
# AWS_REGION=us-east-1
###< AWS S3 Configuration ###

###> Logging ###
# LOG_LEVEL=debug
###< Logging ###

###> Firebase/Push Notifications (if applicable) ###
# FIREBASE_API_KEY=your_firebase_key
# FIREBASE_PROJECT_ID=your_project_id
###< Firebase ###

###> Stripe/Payment Configuration (if applicable) ###
# STRIPE_PUBLIC_KEY=pk_test_your_public_key
# STRIPE_SECRET_KEY=sk_test_your_secret_key
###< Stripe ###
